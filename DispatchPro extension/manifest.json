{
  "manifest_version": 3,
  "name": "D4Y Dispatch4You",
  "version": "1.0.1",
  "description": "DAT One helper for freight dispatchers",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://one.dat.com/*",
    "https://dispatch4you.com/*",
    "https://rtspro.com/*",
    "https://portal.otrsolutions.com/*",
    "https://www.saintjohnfactoring.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://one.dat.com/*"],
      "js": ["vendor/qrcode.js", "content/dat-one.js"],
      "css": ["content/dat-one.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://rtspro.com/*"],
      "js": ["content/autofill-rts.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.saintjohnfactoring.com/*"],
      "js": ["content/autofill-sjc.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  }
}
