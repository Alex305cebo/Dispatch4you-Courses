# Нормализация переносов строк: в репозитории — всегда LF, в рабочей копии
# git подставляет родные для ОС. Убирает фантомные «изменения» CRLF↔LF на Windows.
* text=auto eol=lf

# Бинарные файлы — без нормализации и текстового диффа
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  text
*.mp4  binary
*.webm binary
*.mov  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
