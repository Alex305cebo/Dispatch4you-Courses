{
  "enabled": true,
  "name": "🚀 Автозапуск локального сервера",
  "description": "Автоматически запускает Python HTTP сервер на порту 8000 для локальной разработки",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python -m http.server 8000",
    "timeout": 0
  }
}