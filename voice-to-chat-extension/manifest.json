{
  "manifest_version": 3,
  "name": "Voice-to-Chat: RU → EN",
  "version": "2.0",
  "description": "Диктуй на русском, получай английский перевод. Открывается в полноценной вкладке",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_title": "Открыть Voice-to-Chat"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
