<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
  <defs>
    <radialGradient id="bg" cx="38%" cy="32%" r="70%">
      <stop offset="0%" stop-color="#fb923c"/>
      <stop offset="55%" stop-color="#ea580c"/>
      <stop offset="100%" stop-color="#b91c1c"/>
    </radialGradient>
  </defs>

  <!-- Background circle -->
  <circle cx="32" cy="32" r="30" fill="url(#bg)"/>

  <!-- Truck scaled down ~78% and centered -->
  <g transform="translate(32,32) scale(0.86) translate(-32,-32)">

    <!-- Cargo box / trailer top -->
    <rect x="19" y="7" width="26" height="7" rx="2" fill="#fff"/>

    <!-- Cab body -->
    <rect x="17" y="14" width="30" height="20" rx="2.5" fill="#fff"/>

    <!-- Windshield (gradient cutout) -->
    <rect x="21" y="17" width="22" height="12" rx="2" fill="url(#bg)"/>

    <!-- Wiper -->
    <line x1="23" y1="27.5" x2="31" y2="19" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/>

    <!-- Side mirrors -->
    <rect x="11" y="18" width="6" height="5" rx="1.5" fill="#fff"/>
    <rect x="47" y="18" width="6" height="5" rx="1.5" fill="#fff"/>

    <!-- Grille stripes -->
    <rect x="22" y="35" width="20" height="1.5" rx="0.75" fill="url(#bg)"/>
    <rect x="22" y="37.5" width="20" height="1.5" rx="0.75" fill="url(#bg)"/>
    <rect x="22" y="40" width="20" height="1.5" rx="0.75" fill="url(#bg)"/>

    <!-- Headlights -->
    <circle cx="23.5" cy="41.5" r="2.8" fill="url(#bg)" stroke="#fff" stroke-width="1.5"/>
    <circle cx="40.5" cy="41.5" r="2.8" fill="url(#bg)" stroke="#fff" stroke-width="1.5"/>

    <!-- Front bumper -->
    <rect x="15" y="45" width="34" height="4" rx="2" fill="#fff"/>

    <!-- Wheels -->
    <rect x="20" y="49" width="8" height="8" rx="1.5" fill="#fff"/>
    <rect x="36" y="49" width="8" height="8" rx="1.5" fill="#fff"/>

  </g>
</svg>
