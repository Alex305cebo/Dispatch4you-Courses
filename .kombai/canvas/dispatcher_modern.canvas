anel p-10 border-t-2 border-t-white/10 hover:border-t-cyan-500/50 transition-all duration-500\" data-kid=\"264\">\n        <div class=\"text-white/40 font-bold uppercase tracking-widest text-[10px] mb-8\" data-kid=\"265\">Basic</div>\n        <h3 class=\"text-2xl font-bold mb-2 font-heading\" data-kid=\"266\">Базовый</h3>\n        <div class=\"text-4xl font-black font-heading mb-8\" data-kid=\"267\">FREE</div>\n        <ul class=\"space-y-5 mb-12\" data-kid=\"268\">\n          <li class=\"flex items-center gap-3 text-white/60 text-sm\" data-kid=\"269\">\n            <i class=\"ti ti-circle-check-filled text-cyan-500\" data-kid=\"270\"></i>\n            3 базовых модуля\n          </li>\n          <li class=\"flex items-center gap-3 text-white/60 text-sm\" data-kid=\"271\">\n            <i class=\"ti ti-circle-check-filled text-cyan-500\" data-kid=\"272\"></i>\n            Основная документация\n          </li>\n          <li class=\"flex items-center gap-3 text-white/60 text-sm opacity-30\" data-kid=\"273\">\n            <i class=\"ti ti-circle-x text-white\" data-kid=\"274\"></i>\n            AI-симулятор\n          </li>\n        </ul>\n        <button class=\"w-full py-4 rounded-xl border border-white/10 font-bold hover:bg-white/5 transition-all\" data-kid=\"275\">Выбрать</button>\n      </div>\n\n      \n      <div class=\"glass-panel p-10 scale-105 border-2 border-cyan-500 relative shadow-2xl shadow-cyan-500/10\" data-kid=\"276\">\n        <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 bg-cyan-500 text-black px-4 py-1 rounded text-[10px] font-black uppercase tracking-widest\" data-kid=\"277\">Most Popular</div>\n        <div class=\"text-cyan-400 font-bold uppercase tracking-widest text-[10px] mb-8\" data-kid=\"278\">Professional</div>\n        <h3 class=\"text-2xl font-bold mb-2 font-heading\" data-kid=\"279\">Полный доступ</h3>\n        <div class=\"text-4xl font-black font-heading mb-8\" data-kid=\"280\">$1,000</div>\n        <ul class=\"space-y-5 mb