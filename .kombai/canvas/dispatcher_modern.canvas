      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-void: #050505;\n    --brand-cyan: #06b6d4;\n    --brand-orange: #f97316;\n    --slate-950: #070b14;\n    --glass-border: rgba(255, 255, 255, 0.08);\n    --glass-surface: rgba(255, 255, 255, 0.02);\n  }\n\n  body {\n    background-color: var(--bg-void);\n    color: #f8fafc;\n    font-family: 'Inter', sans-serif;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-mono { font-family: 'Space Grotesk', monospace; }\n\n  /* Expensive Grain Texture Overlay */\n  .grain-overlay {\n    position: fixed;\n    top: 0; left: 0; width: 100%; height: 100%;\n    pointer-events: none;\n    z-index: 9999;\n    opacity: 0.04;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  }\n\n  .text-massive {\n    font-size: clamp(4rem, 8vw, 10rem);\n    line-height: 0.9;\n    letter-spacing: -0.04em;\n    font-weight: 800;\n  }\n\n  .glass-card {\n    background: var(--glass-surface);\n    backdrop-filter: blur(24px);\n    border: 1px solid var(--glass-border);\n    transition: border-color 0.3s ease;\n  }\n\n  .glass-card:hover {\n    border-color: rgba(6, 182, 212, 0.3);\n  }\n\n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    gap: 1px;\n    background: var(--glass-border);\n    border: 1px solid var(--glass-border);\n  }\n\n  .bento-item {\n    background: var(--bg-void);\n    padding: 3rem;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n  }\n\n  .line-draw {\n    position: absolute;\n    background: var(--brand-cyan);\n    opacity: 0.3;\n  }\n\n  .btn-primary {\n    background: #fff;\n    color: #000;\n    padding: 1.25rem 2.5rem;\n    font-weight: 600;\n    letter-spacing: -0.01em;\n    transition: transform 0.2s cubic-bezier(0.2, 0, 0.2, 1);\n  }\n\n  .btn-primary:hover {\n    transform: scale(1.02);\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: var(--bg-void); }\n  ::-webkit-scrollbar-thumb { background: #222; border-radius: 10px; }\n</style>\n\n<div class=\"grain-overlay\" data-kid=\"1\"></div>\n\n\n<nav class=\"fixed top-0 w-full z-50 px-10 py-8 flex justify-between items-center mix-blend-difference\" data-kid=\"2\">\n  <div class=\"flex items-center gap-2\" data-kid=\"3\">\n    <div class=\"w-8 h-8 bg-white rounded-full flex items-center justify-center\" data-kid=\"4\">\n      <div class=\"w-4 h-4 bg-black rounded-sm rotate-45\" data-kid=\"5\"></div>\n    </div>\n    <span class=\"text-xl font-bold tracking-tighter\" data-kid=\"6\">DISPATCH.PRESTIGE</span>\n  </div>\n  <div class=\"flex gap-12 text-sm font-medium opacity-60\" data-kid=\"7\">\n    <a href=\"#curriculum\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"8\">CURRICULUM</a>\n    <a href=\"#simulator\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"9\">TECHNOLOGY</a>\n    <a href=\"#pricing\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"10\">ENROLLMENT</a>\n  </div>\n</nav>\n\n\n<section class=\"relative h-screen flex items-center justify-center overflow-hidden\" data-kid=\"11\">\n  \n  <div class=\"absolute inset-0 z-0\" data-kid=\"12\">\n    <video src=\"https://videos.pexels.com/video-files/35907900/15231598_640_360_25fps.mp4\" poster=\"https://images.pexels.com/videos/35907900/pexels-photo-35907900.jpeg\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover scale-110 opacity-40 brightness-50\" data-kid=\"13\"></video>\n    <div class=\"absolute inset-0 bg-gradient-to-t from-black via-transparent to-black opacity-80\" data-kid=\"14\"></div>\n  </div>\n\n  <div class=\"relative z-10 text-center px-6 max-w-7xl\" data-kid=\"15\">\n    <div class=\"mb-6 overflow-hidden\" data-kid=\"16\">\n      <span class=\"hero-label inline-block font-mono text-xs tracking-[0.4em] uppercase text-cyan-400 font-bold opacity-0 translate-y-full\" data-kid=\"17\">\n        ESTABLISHED 2024 • ELITE STATUS\n      </span>\n    </div>\n    <h1 class=\"text-massive mb-12 flex flex-col items-center\" data-kid=\"18\">\n      <span class=\"reveal-text opacity-0 translate-y-20\" data-kid=\"19\">COMMAND THE</span>\n      <span class=\"reveal-text opacity-0 translate-y-20 text-transparent bg-clip-text bg-gradient-to-b from-white to-gray-500\" data-kid=\"20\">SUPPLY CHAIN</span>\n    </h1>\n    <div class=\"flex flex-col items-center gap-8 opacity-0 hero-cta\" data-kid=\"21\">\n      <p class=\"text-xl text-gray-400 max-w-2xl font-light leading-relaxed\" data-kid=\"22\">\n        The definitive dispatcher training program for the modern logistics landscape. High-performance education for future industry leaders.\n      </p>\n      <div class=\"flex gap-4\" data-kid=\"23\">\n        <a href=\"#pricing\" class=\"btn-primary rounded-full\" data-kid=\"24\">Enroll in Academy</a>\n        <button class=\"px-8 py-4 rounded-full border border-white/10 hover:bg-white/5 transition-colors font-medium\" data-kid=\"25\">View Syllabus</button>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"absolute bottom-12 w-full px-20 flex justify-between items-end\" data-kid=\"26\">\n    <div class=\"flex gap-16 font-mono text-sm opacity-40\" data-kid=\"27\">\n      <div data-kid=\"28\">\n        <div class=\"mb-1 uppercase tracking-widest text-[10px]\" data-kid=\"29\">Active Students</div>\n        <div class=\"text-lg font-bold text-white\" data-kid=\"30\">500+</div>\n      </div>\n      <div data-kid=\"31\">\n        <div class=\"mb-1 uppercase tracking-widest text-[10px]\" data-kid=\"32\">Avg Graduate Income</div>\n        <div class=\"text-lg font-bold text-white\" data-kid=\"33\">$42K / YR</div>\n      </div>\n    </div>\n    <div class=\"animate-bounce\" data-kid=\"34\">\n      <i class=\"ti ti-chevron-down text-2xl opacity-20\" data-kid=\"35\"></i>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-20 border-y border-white/5 bg-black\" data-kid=\"36\">\n  <div class=\"flex flex-col items-center gap-8\" data-kid=\"37\">\n    <span class=\"text-[10px] font-mono tracking-[0.3em] uppercase opacity-30\" data-kid=\"38\">Certified & Compliant With</span>\n    <div class=\"flex justify-center items-center gap-24 opacity-20 grayscale brightness-200\" data-kid=\"39\">\n      <span class=\"text-2xl font-bold tracking-tighter\" data-kid=\"40\">FMCSA</span>\n      <span class=\"text-2xl font-bold tracking-tighter\" data-kid=\"41\">U.S. DOT</span>\n      <span class=\"text-2xl font-bold tracking-tighter\" data-kid=\"42\">DAT ONE</span>\n      <span class=\"text-2xl font-bold tracking-tighter\" data-kid=\"43\">TRUCKSTOP</span>\n      <span class=\"text-2xl font-bold tracking-tighter\" data-kid=\"44\">CH ROBINSON</span>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"curriculum\" class=\"py-40 px-20\" data-kid=\"45\">\n  <div class=\"max-w-7xl mx-auto\" data-kid=\"46\">\n    <div class=\"mb-24 flex justify-between items-end\" data-kid=\"47\">\n      <div class=\"max-w-xl\" data-kid=\"48\">\n        <span class=\"text-cyan-500 font-mono text-sm font-bold tracking-widest uppercase mb-4 block\" data-kid=\"49\">The Advantage</span>\n        <h2 class=\"text-6xl font-bold tracking-tight mb-8\" data-kid=\"50\">Why Dispatchers <br data-kid=\"51\">Choose <span class=\"text-gray-500\" data-kid=\"52\">Our Academy</span></h2>\n      </div>\n      <p class=\"text-gray-400 text-lg max-w-sm font-light mb-4\" data-kid=\"53\">\n        We've engineered every module to deliver precision results, combining deep theory with interactive AI simulations.\n      </p>\n    </div>\n\n    <div class=\"bento-grid\" data-kid=\"54\">\n      \n      <div class=\"bento-item col-span-8 row-span-2 group relative overflow-hidden\" data-kid=\"55\">\n        <div class=\"absolute inset-0 opacity-20 group-hover:opacity-30 transition-opacity\" data-kid=\"56\">\n          <img src=\"https://images.pexels.com/photos/5831269/pexels-photo-5831269.jpeg?auto=compress&cs=tinysrgb&w=1280&q=80\" class=\"w-full h-full object-cover grayscale\" data-kid=\"57\">\n        </div>\n        <div class=\"relative z-10\" data-kid=\"58\">\n          <div class=\"w-12 h-12 bg-cyan-500/20 flex items-center justify-center rounded-xl mb-8 border border-cyan-500/30\" data-kid=\"59\">\n            <i class=\"ti ti-cpu text-2xl text-cyan-400\" data-kid=\"60\"></i>\n          </div>\n          <h3 class=\"text-4xl font-bold mb-4\" data-kid=\"61\">AI Practice Simulator</h3>\n          <p class=\"text-gray-400 max-w-md\" data-kid=\"62\">Train in a risk-free environment. Negotiate with realistic AI brokers, handle difficult carrier situations, and master the load boards before your first real call.</p>\n        </div>\n        <div class=\"relative z-10 font-mono text-6xl font-black text-white/5 group-hover:text-cyan-500/10 transition-colors\" data-kid=\"63\">01</div>\n      </div>\n\n      \n      <div class=\"bento-item col-span-4 group bg-slate-900/20\" data-kid=\"64\">\n        <div data-kid=\"65\">\n          <i class=\"ti ti-users text-3xl mb-8 text-orange-500\" data-kid=\"66\"></i>\n          <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"67\">Elite Community</h3>\n          <p class=\"text-gray-400 text-sm\" data-kid=\"68\">Join a private network of professional dispatchers sharing real-time market data and carrier leads.</p>\n        </div>\n        <div class=\"mt-8 pt-8 border-t border-white/5\" data-kid=\"69\">\n          <span class=\"text-sm font-mono text-orange-500 tracking-tighter\" data-kid=\"70\">500+ ACTIVE MEMBERS</span>\n        </div>\n      </div>\n\n      \n      <div class=\"bento-item col-span-4 group\" data-kid=\"71\">\n        <div data-kid=\"72\">\n          <i class=\"ti ti-shield-check text-3xl mb-8 text-blue-500\" data-kid=\"73\"></i>\n          <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"74\">Compliance Mastery</h3>\n          <p class=\"text-gray-400 text-sm\" data-kid=\"75\">Deep immersion into FMCSA and DOT regulations. Master Rate Cons, BOLs, and PODs with zero margin for error.</p>\n        </div>\n      </div>\n\n      \n      <div class=\"bento-item col-span-12 h-40 flex-row items-center justify-between border-t border-white/5\" data-kid=\"76\">\n        <div class=\"flex items-center gap-6\" data-kid=\"77\">\n          <div class=\"w-2 h-2 bg-green-500 rounded-full animate-pulse\" data-kid=\"78\"></div>\n          <span class=\"font-mono text-sm tracking-widest text-gray-400\" data-kid=\"79\">NEXT COHORT ENROLLMENT: JUNE 28, 2024</span>\n        </div>\n        <button class=\"text-sm font-bold border-b border-white/20 hover:border-white transition-colors py-2\" data-kid=\"80\">View Academy Schedule →</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"simulator\" class=\"py-40 bg-[#020202] relative overflow-hidden\" data-kid=\"81\">\n  <div class=\"max-w-7xl mx-auto px-20\" data-kid=\"82\">\n    <div class=\"grid grid-cols-2 gap-24 items-center\" data-kid=\"83\">\n      <div class=\"relative\" data-kid=\"84\">\n        <div class=\"absolute -top-20 -left-20 w-96 h-96 bg-cyan-600/10 blur-[120px] rounded-full\" data-kid=\"85\"></div>\n        <div class=\"relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-cyan-900/10\" data-kid=\"86\">\n          <img src=\"https://images.unsplash.com/photo-1766019463451-04e0b1269f37?q=80&w=1280&auto=format&fit=crop\" class=\"w-full grayscale brightness-75 hover:grayscale-0 transition-all duration-1000\" data-kid=\"87\">\n          \n          \n          <div class=\"absolute top-1/4 left-1/4 glass-card p-4 rounded-xl shadow-2xl stats-reveal\" data-kid=\"88\">\n            <div class=\"flex items-center gap-3\" data-kid=\"89\">\n              <div class=\"w-2 h-2 bg-cyan-500 rounded-full\" data-kid=\"90\"></div>\n              <span class=\"text-[10px] font-mono font-bold\" data-kid=\"91\">LIVE ROUTE ANALYTICS</span>\n            </div>\n          </div>\n          <div class=\"absolute bottom-1/3 right-1/4 glass-card p-4 rounded-xl shadow-2xl stats-reveal\" data-kid=\"92\">\n            <div class=\"flex items-center gap-3\" data-kid=\"93\">\n              <div class=\"w-2 h-2 bg-orange-500 rounded-full\" data-kid=\"94\"></div>\n              <span class=\"text-[10px] font-mono font-bold\" data-kid=\"95\">INSTANT RATE QUOTES</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div data-kid=\"96\">\n        <h2 class=\"text-5xl font-bold tracking-tight mb-10 leading-tight\" data-kid=\"97\">Engineered for <br data-kid=\"98\">High Performance</h2>\n        <div class=\"space-y-12\" data-kid=\"99\">\n          <div class=\"flex gap-8 group\" data-kid=\"100\">\n            <div class=\"flex-shrink-0 w-14 h-14 rounded-full border border-white/10 flex items-center justify-center group-hover:border-cyan-500/50 transition-colors\" data-kid=\"101\">\n              <i class=\"ti ti-activity text-2xl text-gray-500 group-hover:text-cyan-400\" data-kid=\"102\"></i>\n            </div>\n            <div data-kid=\"103\">\n              <h4 class=\"text-lg font-bold mb-2\" data-kid=\"104\">Real-Time Dashboards</h4>\n              <p class=\"text-gray-400 text-sm leading-relaxed\" data-kid=\"105\">Access our proprietary simulation software that mirrors actual load boards used by top US dispatch agencies.</p>\n            </div>\n          </div>\n          <div class=\"flex gap-8 group\" data-kid=\"106\">\n            <div class=\"flex-shrink-0 w-14 h-14 rounded-full border border-white/10 flex items-center justify-center group-hover:border-cyan-500/50 transition-colors\" data-kid=\"107\">\n              <i class=\"ti ti-chart-bar text-2xl text-gray-500 group-hover:text-cyan-400\" data-kid=\"108\"></i>\n            </div>\n            <div data-kid=\"109\">\n              <h4 class=\"text-lg font-bold mb-2\" data-kid=\"110\">Advanced Market Metrics</h4>\n              <p class=\"text-gray-400 text-sm leading-relaxed\" data-kid=\"111\">Learn to read the market. Understand load-to-truck ratios, seasonal fluctuations, and geographic hot-zones.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"pricing\" class=\"py-40 px-20\" data-kid=\"112\">\n  <div class=\"max-w-7xl mx-auto text-center mb-24\" data-kid=\"113\">\n    <h2 class=\"text-6xl font-bold tracking-tighter mb-6\" data-kid=\"114\">Investment into Excellence</h2>\n    <p class=\"text-gray-500 max-w-2xl mx-auto font-light\" data-kid=\"115\">Select the tier that aligns with your professional ambitions. Each plan includes lifetime updates and core certification.</p>\n  </div>\n\n  <div class=\"max-w-6xl mx-auto grid grid-cols-3 gap-8\" data-kid=\"116\">\n    \n    <div class=\"p-12 glass-card rounded-3xl flex flex-col justify-between group\" data-kid=\"117\">\n      <div data-kid=\"118\">\n        <div class=\"text-xs font-mono font-bold tracking-widest text-gray-500 mb-12\" data-kid=\"119\">FOUNDATION</div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"120\">Basic</h3>\n        <div class=\"text-5xl font-bold mb-10\" data-kid=\"121\">$0</div>\n        <ul class=\"space-y-4 text-sm text-gray-400\" data-kid=\"122\">\n          <li class=\"flex items-center gap-3\" data-kid=\"123\"><span class=\"font-mono text-white\" data-kid=\"124\">[x]</span> Intro to Dispatching</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"125\"><span class=\"font-mono text-white\" data-kid=\"126\">[x]</span> Glossary & Terms</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"127\"><span class=\"font-mono text-white\" data-kid=\"128\">[x]</span> Basic Documentation</li>\n          <li class=\"flex items-center gap-3 opacity-20\" data-kid=\"129\"><span class=\"font-mono\" data-kid=\"130\">[ ]</span> AI Simulator</li>\n          <li class=\"flex items-center gap-3 opacity-20\" data-kid=\"131\"><span class=\"font-mono\" data-kid=\"132\">[ ]</span> Mentorship Access</li>\n        </ul>\n      </div>\n      <button class=\"mt-16 w-full py-4 rounded-xl border border-white/10 group-hover:bg-white/5 transition-colors font-bold\" data-kid=\"133\">Start Foundation</button>\n    </div>\n\n    \n    <div class=\"p-12 glass-card rounded-3xl flex flex-col justify-between relative group scale-105 bg-white/[0.03] border-cyan-500/30\" data-kid=\"134\">\n      <div class=\"absolute -inset-4 bg-cyan-500/5 blur-3xl rounded-full -z-10 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"135\"></div>\n      <div data-kid=\"136\">\n        <div class=\"text-xs font-mono font-bold tracking-widest text-cyan-500 mb-12\" data-kid=\"137\">THE STANDARD</div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"138\">Full Access</h3>\n        <div class=\"text-5xl font-bold mb-2\" data-kid=\"139\">$1,000</div>\n        <div class=\"text-[10px] font-mono text-cyan-400 mb-10\" data-kid=\"140\">LIFETIME ACCESS • NO MONTHLY FEES</div>\n        <ul class=\"space-y-4 text-sm text-gray-300\" data-kid=\"141\">\n          <li class=\"flex items-center gap-3\" data-kid=\"142\"><span class=\"font-mono text-cyan-400\" data-kid=\"143\">[x]</span> All 15 Mastery Modules</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"144\"><span class=\"font-mono text-cyan-400\" data-kid=\"145\">[x]</span> 24/7 Support Channel</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"146\"><span class=\"font-mono text-cyan-400\" data-kid=\"147\">[x]</span> Advanced Negotiations</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"148\"><span class=\"font-mono text-cyan-400\" data-kid=\"149\">[x]</span> AI Simulator Pro</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"150\"><span class=\"font-mono text-cyan-400\" data-kid=\"151\">[x]</span> Career Strategy Session</li>\n        </ul>\n      </div>\n      <button class=\"mt-16 w-full py-4 rounded-xl bg-cyan-500 hover:bg-cyan-400 text-black font-bold transition-colors\" data-kid=\"152\">Select Standard</button>\n    </div>\n\n    \n    <div class=\"p-12 glass-card rounded-3xl flex flex-col justify-between group border-orange-500/20\" data-kid=\"153\">\n      <div data-kid=\"154\">\n        <div class=\"text-xs font-mono font-bold tracking-widest text-orange-500 mb-12\" data-kid=\"155\">ELITE TIER</div>\n        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"156\">Premium</h3>\n        <div class=\"text-5xl font-bold mb-10\" data-kid=\"157\">$1,750</div>\n        <ul class=\"space-y-4 text-sm text-gray-300\" data-kid=\"158\">\n          <li class=\"flex items-center gap-3\" data-kid=\"159\"><span class=\"font-mono text-orange-500\" data-kid=\"160\">[x]</span> Everything in Standard</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"161\"><span class=\"font-mono text-orange-500\" data-kid=\"162\">[x]</span> Personal Mentor (1-on-1)</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"163\"><span class=\"font-mono text-orange-500\" data-kid=\"164\">[x]</span> Guaranteed Interview Base</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"165\"><span class=\"font-mono text-orange-500\" data-kid=\"166\">[x]</span> LLC Formation Support</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"167\"><span class=\"font-mono text-orange-500\" data-kid=\"168\">[x]</span> Advanced Broker Database</li>\n        </ul>\n      </div>\n      <button class=\"mt-16 w-full py-4 rounded-xl border border-orange-500/20 group-hover:bg-orange-500/5 transition-colors font-bold text-orange-500\" data-kid=\"169\">Apply for Elite</button>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-40 bg-[#050505] relative overflow-hidden text-center\" data-kid=\"170\">\n  <div class=\"absolute inset-0 opacity-10 grayscale pointer-events-none\" data-kid=\"171\">\n    <img src=\"https://images.unsplash.com/photo-1590504805643-bb1f94cde7fd?q=80&w=1440&auto=format&fit=crop\" class=\"w-full h-full object-cover\" data-kid=\"172\">\n  </div>\n  <div class=\"relative z-10 max-w-4xl mx-auto px-6\" data-kid=\"173\">\n    <div class=\"inline-block px-4 py-1 rounded-full border border-white/10 text-[10px] font-mono tracking-widest mb-10 uppercase\" data-kid=\"174\">Your Career Upgrade Starts Here</div>\n    <h2 class=\"text-7xl font-extrabold tracking-tighter mb-12 leading-[1.1]\" data-kid=\"175\">Join the New Standard <br data-kid=\"176\">in Modern Logistics.</h2>\n    <div class=\"flex justify-center gap-6\" data-kid=\"177\">\n      <button class=\"btn-primary rounded-full px-12 py-5 text-lg\" data-kid=\"178\">Secure Your Seat</button>\n      <button class=\"px-12 py-5 rounded-full border border-white/20 hover:bg-white/5 transition-colors font-bold\" data-kid=\"179\">Speak with Advisor</button>\n    </div>\n    <div class=\"mt-16 flex justify-center items-center gap-8 opacity-40\" data-kid=\"180\">\n      <div class=\"flex items-center gap-2\" data-kid=\"181\"><i class=\"ti ti-shield text-xl\" data-kid=\"182\"></i> <span class=\"text-xs font-mono uppercase tracking-widest\" data-kid=\"183\">Safe Payment</span></div>\n      <div class=\"flex items-center gap-2\" data-kid=\"184\"><i class=\"ti ti-refresh text-xl\" data-kid=\"185\"></i> <span class=\"text-xs font-mono uppercase tracking-widest\" data-kid=\"186\">30-Day Guarantee</span></div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"py-20 px-20 border-t border-white/5 flex justify-between items-center bg-black\" data-kid=\"187\">\n  <div class=\"flex items-center gap-2 opacity-50\" data-kid=\"188\">\n    <div class=\"w-6 h-6 bg-white rounded-full flex items-center justify-center\" data-kid=\"189\">\n      <div class=\"w-3 h-3 bg-black rounded-sm rotate-45\" data-kid=\"190\"></div>\n    </div>\n    <span class=\"text-lg font-bold tracking-tighter uppercase\" data-kid=\"191\">DISPATCH.PRESTIGE</span>\n  </div>\n  <div class=\"text-[10px] font-mono uppercase opacity-30 tracking-[0.2em]\" data-kid=\"192\">\n    © 2024 DISPATCH4YOU ACADEMY • PRIVACY • TERMS • FMCSA COMPLIANT\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"193\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"194\"></script>\n\n<script data-kid=\"195\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  window.addEventListener('load', () => {\n    const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.5 } });\n\n    // Hero Entry\n    tl.to('.hero-label', { y: 0, opacity: 1, duration: 1 }, 0.5)\n      .to('.reveal-text', { y: 0, opacity: 1, stagger: 0.15 }, 0.8)\n      .to('.hero-cta', { opacity: 1, y: 0, duration: 1 }, 1.2)\n      .from('nav', { y: -100, opacity: 0, duration: 1 }, 1.5);\n\n    // Parallax Video\n    gsap.to('video', {\n      scrollTrigger: {\n        trigger: 'section',\n        start: 'top top',\n        end: 'bottom top',\n        scrub: true\n      },\n      yPercent: 15,\n      ease: 'none'\n    });\n\n    // Bento Grid Animation\n    gsap.from('.bento-item', {\n      scrollTrigger: {\n        trigger: '.bento-grid',\n        start: 'top 80%',\n      },\n      y: 100,\n      opacity: 0,\n      stagger: 0.1,\n      duration: 1,\n      ease: 'power3.out'\n    });\n\n    // Interface Reveal\n    gsap.from('.stats-reveal', {\n      scrollTrigger: {\n        trigger: '#simulator',\n        start: 'top 60%',\n      },\n      scale: 0.8,\n      opacity: 0,\n      stagger: 0.3,\n      duration: 1.5,\n      ease: 'elastic.out(1, 0.5)'\n    });\n\n    // Pricing Entrance\n    gsap.from('.pricing-card, .glass-card', {\n      scrollTrigger: {\n        trigger: '#pricing',\n        start: 'top 70%',\n      },\n      y: 50,\n      opacity: 0,\n      stagger: 0.1,\n      duration: 1,\n      ease: 'power3.out'\n    });\n\n    // Mouse tilt effect for bento items\n    const bentoItems = document.querySelectorAll('.bento-item');\n    bentoItems.forEach(item => {\n      item.addEventListener('mousemove', (e) => {\n        const rect = item.getBoundingClientRect();\n        const x = e.clientX - rect.left;\n        const y = e.clientY - rect.top;\n        const centerX = rect.width / 2;\n        const centerY = rect.height / 2;\n        const rotateX = (y - centerY) / 20;\n        const rotateY = (centerX - x) / 20;\n\n        gsap.to(item, {\n          rotateX: rotateX,\n          rotateY: rotateY,\n          duration: 0.5,\n          ease: 'power2.out'\n        });\n      });\n\n      item.addEventListener('mouseleave', () => {\n        gsap.to(item, {\n          rotateX: 0,\n          rotateY: 0,\n          duration: 0.5,\n          ease: 'power2.out'\n        });\n      });\n    });\n  });\n</script>",
