      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary: #06b6d4;\n    --secondary: #0ea5e9;\n    --accent: #f97316;\n    --bg-darker: #070b14;\n    --bg-dark: #0a0e1a;\n    --glass: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--bg-darker);\n    color: #ffffff;\n    font-family: 'Inter', sans-serif;\n    overflow-x: hidden;\n  }\n\n  .font-heading { font-family: 'Montserrat', sans-serif; }\n  \n  .glass-panel {\n    background: var(--glass);\n    backdrop-filter: blur(24px);\n    border: 1px solid var(--glass-border);\n    border-radius: 24px;\n  }\n\n  .cyan-glow {\n    box-shadow: 0 0 20px rgba(6, 182, 212, 0.2);\n  }\n\n  /* Grid Background Pattern */\n  .grid-bg {\n    background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),\n                      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .spline-path {\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n  }\n</style>\n\n\n<nav class=\"fixed top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center bg-black/10 backdrop-blur-md border-b border-white/5\" data-kid=\"1\">\n  <div class=\"flex items-center gap-3\" data-kid=\"2\">\n    <div class=\"w-10 h-10 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-lg flex items-center justify-center shadow-lg shadow-cyan-500/20\" data-kid=\"3\">\n      <i class=\"ti ti-truck-delivery text-white text-xl\" data-kid=\"4\"></i>\n    </div>\n    <span class=\"text-xl font-bold tracking-tight font-heading uppercase\" data-kid=\"5\">Dispatch<span class=\"text-cyan-400\" data-kid=\"6\">4</span>You</span>\n  </div>\n  <div class=\"hidden md:flex items-center gap-10 text-sm font-medium text-white/60\" data-kid=\"7\">\n    <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"8\">Программа</a>\n    <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"9\">Преимущества</a>\n    <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"10\">Тренажер</a>\n    <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"11\">Тарифы</a>\n  </div>\n  <div class=\"flex items-center gap-6\" data-kid=\"12\">\n    <a href=\"#\" class=\"text-sm font-semibold hover:text-cyan-400 transition-colors\" data-kid=\"13\">Войти</a>\n    <button class=\"bg-cyan-500 hover:bg-cyan-400 text-black px-6 py-2.5 rounded-full text-sm font-bold transition-all shadow-lg shadow-cyan-500/20\" data-kid=\"14\">Начать обучение</button>\n  </div>\n</nav>\n\n<main class=\"grid-bg\" data-kid=\"15\">\n  \n  <section class=\"relative min-h-screen flex items-center pt-20 overflow-hidden\" data-kid=\"16\">\n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"17\">\n      <video src=\"https://videos.pexels.com/video-files/19613427/19613427-uhd_2560_1440_24fps.mp4\" poster=\"https://images.pexels.com/videos/19613427/cargo-truck-cars-city-traffic-delivery-truck-19613427.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover opacity-40 grayscale brightness-50\" data-kid=\"18\">\n      </video>\n      <div class=\"absolute inset-0 bg-gradient-to-r from-bg-darker via-bg-darker/80 to-transparent\" data-kid=\"19\"></div>\n    </div>\n\n    <div class=\"container mx-auto px-12 relative z-10\" data-kid=\"20\">\n      <div class=\"max-w-3xl hero-reveal\" data-kid=\"21\">\n        <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 text-xs font-bold uppercase tracking-widest mb-8\" data-kid=\"22\">\n          <span class=\"w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"23\"></span>\n          Набор открыт • Весна 2026\n        </div>\n        <h1 class=\"text-7xl lg:text-8xl font-black font-heading leading-tight mb-8\" data-kid=\"24\">\n          Command the <br data-kid=\"25\">\n          <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500\" data-kid=\"26\">Supply Chain.</span>\n        </h1>\n        <p class=\"text-xl text-white/60 leading-relaxed max-w-xl mb-12\" data-kid=\"27\">\n          Элитное обучение диспетчеров грузоперевозок для современного логистического ландшафта. Станьте профессионалом в индустрии с оборотом $875 млрд.\n        </p>\n        \n        <div class=\"flex items-center gap-6\" data-kid=\"28\">\n          <button class=\"px-8 py-4 bg-white text-black rounded-xl font-bold flex items-center gap-3 hover:bg-cyan-400 transition-all group\" data-kid=\"29\">\n            Начать карьеру\n            <i class=\"ti ti-arrow-up-right group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform\" data-kid=\"30\"></i>\n          </button>\n          <a href=\"#\" class=\"px-8 py-4 rounded-xl border border-white/10 hover:bg-white/5 font-bold transition-all\" data-kid=\"31\">Смотреть программу</a>\n        </div>\n\n        <div class=\"mt-20 flex gap-12 border-t border-white/5 pt-10 max-w-xl\" data-kid=\"32\">\n          <div data-kid=\"33\">\n            <div class=\"text-3xl font-bold text-white mb-1 font-heading\" data-kid=\"34\">500+</div>\n            <div class=\"text-xs font-semibold text-white/40 uppercase tracking-wider\" data-kid=\"35\">Студентов</div>\n          </div>\n          <div data-kid=\"36\">\n            <div class=\"text-3xl font-bold text-white mb-1 font-heading\" data-kid=\"37\">4.8/5</div>\n            <div class=\"text-xs font-semibold text-white/40 uppercase tracking-wider\" data-kid=\"38\">Рейтинг курса</div>\n          </div>\n          <div data-kid=\"39\">\n            <div class=\"text-3xl font-bold text-white mb-1 font-heading\" data-kid=\"40\">24/7</div>\n            <div class=\"text-xs font-semibold text-white/40 uppercase tracking-wider\" data-kid=\"41\">Поддержка</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-white/20\" data-kid=\"42\">\n      <span class=\"text-[10px] font-bold uppercase tracking-[0.3em]\" data-kid=\"43\">Scroll</span>\n      <div class=\"w-px h-20 bg-gradient-to-b from-cyan-500/50 to-transparent\" data-kid=\"44\"></div>\n    </div>\n  </section>\n\n  \n  <div class=\"py-12 border-y border-white/5 bg-black/20\" data-kid=\"45\">\n    <div class=\"flex items-center gap-16 overflow-hidden select-none whitespace-nowrap opacity-30 marquee-container\" data-kid=\"46\">\n      <span class=\"text-xs font-bold uppercase tracking-[0.5em] text-white/60 mx-8\" data-kid=\"47\">Certified by & Compliant with:</span>\n      <div class=\"flex gap-20 items-center logos-marquee\" data-kid=\"48\">\n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"49\">FMCSA</span>\n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"50\">U.S. DOT</span>\n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"51\">DAT SOLUTIONS</span>\n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"52\">TRUCKSTOP</span>\n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"53\">FEDERAL REGISTER</span>\n        \n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"54\">FMCSA</span>\n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"55\">U.S. DOT</span>\n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"56\">DAT SOLUTIONS</span>\n        <span class=\"text-2xl font-black font-heading opacity-60\" data-kid=\"57\">TRUCKSTOP</span>\n      </div>\n    </div>\n  </div>\n\n  \n  <section class=\"py-32 relative overflow-hidden\" data-kid=\"58\">\n    <div class=\"container mx-auto px-12\" data-kid=\"59\">\n      <div class=\"flex justify-between items-end mb-20\" data-kid=\"60\">\n        <div data-kid=\"61\">\n          <div class=\"text-cyan-500 font-bold uppercase tracking-[0.3em] text-xs mb-4\" data-kid=\"62\">Core Advantage</div>\n          <h2 class=\"text-5xl font-black font-heading\" data-kid=\"63\">Почему выбирают нас</h2>\n        </div>\n        <p class=\"max-w-md text-white/50 leading-relaxed\" data-kid=\"64\">Эксклюзивная платформа, где теория встречается с высокотехнологичной практикой в реальном времени.</p>\n      </div>\n\n      <div class=\"grid grid-cols-12 gap-6 bento-reveal\" data-kid=\"65\">\n        \n        <div class=\"col-span-12 lg:col-span-8 group\" data-kid=\"66\">\n          <div class=\"glass-panel p-10 h-full relative overflow-hidden transition-all duration-500 hover:border-cyan-500/50\" data-kid=\"67\">\n            <div class=\"relative z-10\" data-kid=\"68\">\n              <div class=\"w-16 h-16 rounded-2xl bg-cyan-500/10 flex items-center justify-center mb-8 border border-cyan-500/20\" data-kid=\"69\">\n                <i class=\"ti ti-cpu text-3xl text-cyan-400\" data-kid=\"70\"></i>\n              </div>\n              <h3 class=\"text-3xl font-bold mb-4 font-heading\" data-kid=\"71\">AI Practice Simulator</h3>\n              <p class=\"text-white/50 text-lg leading-relaxed max-w-lg\" data-kid=\"72\">\n                Тренируйтесь вести переговоры с брокерами в продвинутом AI-симуляторе. 50+ сценариев реальных звонков, мгновенная обратная связь и анализ ошибок.\n              </p>\n              <div class=\"mt-10 flex items-center gap-4\" data-kid=\"73\">\n                <div class=\"flex -space-x-3\" data-kid=\"74\">\n                  <img src=\"https://i.pravatar.cc/40?u=1\" class=\"w-10 h-10 rounded-full border-2 border-bg-dark\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"75\">\n                  <img src=\"https://i.pravatar.cc/40?u=2\" class=\"w-10 h-10 rounded-full border-2 border-bg-dark\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"76\">\n                  <img src=\"https://i.pravatar.cc/40?u=3\" class=\"w-10 h-10 rounded-full border-2 border-bg-dark\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"77\">\n                </div>\n                <span class=\"text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"78\">+120 студентов уже в системе</span>\n              </div>\n            </div>\n            \n            <img src=\"https://images.pexels.com/photos/5831269/pexels-photo-5831269.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"absolute bottom-0 right-0 w-1/2 opacity-20 group-hover:opacity-40 transition-opacity duration-700 pointer-events-none grayscale\" alt=\"Tech background\" decoding=\"async\" loading=\"lazy\" data-kid=\"79\">\n          </div>\n        </div>\n        \n        \n        <div class=\"col-span-12 lg:col-span-4 group\" data-kid=\"80\">\n          <div class=\"glass-panel p-10 h-full transition-all duration-500 hover:border-blue-500/50\" data-kid=\"81\">\n            <div class=\"w-16 h-16 rounded-2xl bg-blue-500/10 flex items-center justify-center mb-8 border border-blue-500/20\" data-kid=\"82\">\n              <i class=\"ti ti-headset text-3xl text-blue-400\" data-kid=\"83\"></i>\n            </div>\n            <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"84\">24/7 Менторы</h3>\n            <p class=\"text-white/50 leading-relaxed mb-8\" data-kid=\"85\">\n              Действующие диспетчеры отвечают на вопросы в закрытом чате. Разбор ошибок каждую неделю.\n            </p>\n            <div class=\"pt-6 border-t border-white/5\" data-kid=\"86\">\n              <span class=\"text-[10px] font-bold uppercase tracking-widest text-white/40\" data-kid=\"87\">Response time</span>\n              <div class=\"text-xl font-bold text-white mt-1\" data-kid=\"88\">~15 Minutes</div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-4 group\" data-kid=\"89\">\n          <div class=\"glass-panel p-10 h-full transition-all duration-500 hover:border-orange-500/50\" data-kid=\"90\">\n            <div class=\"w-16 h-16 rounded-2xl bg-orange-500/10 flex items-center justify-center mb-8 border border-orange-500/20\" data-kid=\"91\">\n              <i class=\"ti ti-trending-up text-3xl text-orange-400\" data-kid=\"92\"></i>\n            </div>\n            <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"93\">Career Path</h3>\n            <p class=\"text-white/50 leading-relaxed mb-8\" data-kid=\"94\">\n              Помощь с резюме, подготовка к собеседованию и прямой доступ к базе вакансий в США.\n            </p>\n            <div class=\"flex items-center gap-2\" data-kid=\"95\">\n              <div class=\"h-1.5 flex-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"96\">\n                <div class=\"h-full bg-orange-500 w-[87%]\" data-kid=\"97\"></div>\n              </div>\n              <span class=\"text-xs font-bold text-orange-400\" data-kid=\"98\">87%</span>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-4 group\" data-kid=\"99\">\n          <div class=\"glass-panel p-10 h-full transition-all duration-500 hover:border-purple-500/50\" data-kid=\"100\">\n            <div class=\"w-16 h-16 rounded-2xl bg-purple-500/10 flex items-center justify-center mb-8 border border-purple-500/20\" data-kid=\"101\">\n              <i class=\"ti ti-file-text text-3xl text-purple-400\" data-kid=\"102\"></i>\n            </div>\n            <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"103\">Full Docs Hub</h3>\n            <p class=\"text-white/50 leading-relaxed mb-8\" data-kid=\"104\">\n              Rate Con, BOL, POD, Invoice — все документы с интерактивными примерами и чек-листами.\n            </p>\n            <span class=\"text-xs font-bold text-white/20 uppercase tracking-widest\" data-kid=\"105\">15+ Types Included</span>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-4 group\" data-kid=\"106\">\n          <div class=\"glass-panel p-10 h-full transition-all duration-500 hover:border-green-500/50\" data-kid=\"107\">\n            <div class=\"w-16 h-16 rounded-2xl bg-green-500/10 flex items-center justify-center mb-8 border border-green-500/20\" data-kid=\"108\">\n              <i class=\"ti ti-activity text-3xl text-green-400\" data-kid=\"109\"></i>\n            </div>\n            <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"110\">Monthly Updates</h3>\n            <p class=\"text-white/50 leading-relaxed mb-8\" data-kid=\"111\">\n              Новые правила DOT, изменения ставок и тренды рынка. Обновляется каждый месяц.\n            </p>\n            <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-md bg-green-500/10 border border-green-500/30 text-green-400 text-[10px] font-bold uppercase\" data-kid=\"112\">\n              Last updated: May 2026\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-bg-dark/50 overflow-hidden\" data-kid=\"113\">\n    <div class=\"container mx-auto px-12 mb-16\" data-kid=\"114\">\n      <h2 class=\"text-4xl font-black font-heading mb-4\" data-kid=\"115\">Что вы получите</h2>\n      <p class=\"text-white/40 max-w-xl leading-relaxed\" data-kid=\"116\">Полный технологический стек инструментов для работы на рынке грузоперевозок США.</p>\n    </div>\n\n    <div class=\"flex gap-8 px-12 overflow-x-auto no-scrollbar feature-cards-scroll\" data-kid=\"117\">\n      \n      <div class=\"min-w-[400px] glass-panel p-12 group hover:bg-white/5 transition-all duration-500 border-b-4 border-b-transparent hover:border-b-cyan-500\" data-kid=\"118\">\n        <span class=\"text-[10px] font-black text-white/20 uppercase tracking-[0.5em] mb-10 block\" data-kid=\"119\">Module 01</span>\n        <h3 class=\"text-3xl font-bold mb-6 font-heading\" data-kid=\"120\">База знаний</h3>\n        <p class=\"text-white/40 leading-relaxed mb-10\" data-kid=\"121\">Полная документация диспетчера США с шаблонами, чек-листами и пошаговыми инструкциями.</p>\n        <div class=\"flex justify-between items-center\" data-kid=\"122\">\n          <i class=\"ti ti-book-2 text-4xl text-cyan-500/50\" data-kid=\"123\"></i>\n          <i class=\"ti ti-chevron-right text-xl opacity-0 group-hover:opacity-100 transition-all group-hover:translate-x-2\" data-kid=\"124\"></i>\n        </div>\n      </div>\n      \n      <div class=\"min-w-[400px] glass-panel p-12 group hover:bg-white/5 transition-all duration-500 border-b-4 border-b-transparent hover:border-b-cyan-500\" data-kid=\"125\">\n        <span class=\"text-[10px] font-black text-white/20 uppercase tracking-[0.5em] mb-10 block\" data-kid=\"126\">Module 02</span>\n        <h3 class=\"text-3xl font-bold mb-6 font-heading\" data-kid=\"127\">AI Simulator</h3>\n        <p class=\"text-white/40 leading-relaxed mb-10\" data-kid=\"128\">Переговоры с брокерами в реальном времени. Отработайте возражения до выхода на работу.</p>\n        <div class=\"flex justify-between items-center\" data-kid=\"129\">\n          <i class=\"ti ti-message-chatbot text-4xl text-cyan-500/50\" data-kid=\"130\"></i>\n          <i class=\"ti ti-chevron-right text-xl opacity-0 group-hover:opacity-100 transition-all group-hover:translate-x-2\" data-kid=\"131\"></i>\n        </div>\n      </div>\n      <div class=\"min-w-[400px] glass-panel p-12 group hover:bg-white/5 transition-all duration-500 border-b-4 border-b-transparent hover:border-b-cyan-500\" data-kid=\"132\">\n        <span class=\"text-[10px] font-black text-white/20 uppercase tracking-[0.5em] mb-10 block\" data-kid=\"133\">Module 03</span>\n        <h3 class=\"text-3xl font-bold mb-6 font-heading\" data-kid=\"134\">Analytics Hub</h3>\n        <p class=\"text-white/40 leading-relaxed mb-10\" data-kid=\"135\">Инструменты для анализа рынка, прогнозирования ставок и оптимизации маршрутов.</p>\n        <div class=\"flex justify-between items-center\" data-kid=\"136\">\n          <i class=\"ti ti-chart-bar text-4xl text-cyan-500/50\" data-kid=\"137\"></i>\n          <i class=\"ti ti-chevron-right text-xl opacity-0 group-hover:opacity-100 transition-all group-hover:translate-x-2\" data-kid=\"138\"></i>\n        </div>\n      </div>\n      <div class=\"min-w-[400px] glass-panel p-12 group hover:bg-white/5 transition-all duration-500 border-b-4 border-b-transparent hover:border-b-cyan-500\" data-kid=\"139\">\n        <span class=\"text-[10px] font-black text-white/20 uppercase tracking-[0.5em] mb-10 block\" data-kid=\"140\">Module 04</span>\n        <h3 class=\"text-3xl font-bold mb-6 font-heading\" data-kid=\"141\">Legal Mastery</h3>\n        <p class=\"text-white/40 leading-relaxed mb-10\" data-kid=\"142\">Compliance и регуляции DOT/FMCSA. Работайте без рисков и штрафов.</p>\n        <div class=\"flex justify-between items-center\" data-kid=\"143\">\n          <i class=\"ti ti-shield-check text-4xl text-cyan-500/50\" data-kid=\"144\"></i>\n          <i class=\"ti ti-chevron-right text-xl opacity-0 group-hover:opacity-100 transition-all group-hover:translate-x-2\" data-kid=\"145\"></i>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative h-[600px] flex items-center overflow-hidden\" data-kid=\"146\">\n    <div class=\"absolute inset-0 z-0 scale-110 parallax-bg\" data-kid=\"147\">\n      <video src=\"https://videos.pexels.com/video-files/34342926/14549300_360_640_30fps.mp4\" poster=\"https://images.pexels.com/videos/34342926/pexels-photo-34342926.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover opacity-60\" data-kid=\"148\">\n      </video>\n      <div class=\"absolute inset-0 bg-gradient-to-t from-bg-darker via-transparent to-bg-darker\" data-kid=\"149\"></div>\n      <div class=\"absolute inset-0 bg-cyan-900/10 mix-blend-overlay\" data-kid=\"150\"></div>\n    </div>\n\n    <div class=\"container mx-auto px-12 relative z-10\" data-kid=\"151\">\n      <div class=\"max-w-xl p-12 glass-panel border-cyan-500/30\" data-kid=\"152\">\n        <div class=\"text-cyan-400 font-black uppercase tracking-[0.4em] text-xs mb-6\" data-kid=\"153\">Simulation Technology</div>\n        <h2 class=\"text-5xl font-black font-heading mb-6 leading-tight\" data-kid=\"154\">Интерактивный тренажер карт США</h2>\n        <p class=\"text-white/70 text-lg mb-10 leading-relaxed\" data-kid=\"155\">\n          Изучите географию штатов, часовые пояса и основные маршруты в игровом формате. Точность и скорость принятия решений — ваши главные инструменты.\n        </p>\n        <button class=\"bg-cyan-500 hover:bg-white text-black px-10 py-4 rounded-xl font-black uppercase tracking-widest transition-all shadow-xl shadow-cyan-500/20\" data-kid=\"156\">Запустить симулятор</button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 relative\" data-kid=\"157\">\n    <div class=\"container mx-auto px-12\" data-kid=\"158\">\n      <div class=\"grid grid-cols-12 gap-16 items-start\" data-kid=\"159\">\n        \n        <div class=\"col-span-12 lg:col-span-5 lg:sticky lg:top-32\" data-kid=\"160\">\n          <div class=\"text-orange-500 font-bold uppercase tracking-[0.3em] text-xs mb-4\" data-kid=\"161\">Market Outlook</div>\n          <h2 class=\"text-5xl font-black font-heading mb-10 leading-tight\" data-kid=\"162\">Почему Диспетчер — это профессия <span class=\"text-white/30\" data-kid=\"163\">будущего</span></h2>\n          \n          <div class=\"space-y-12 mt-16\" data-kid=\"164\">\n            <div class=\"relative pl-8 border-l-2 border-cyan-500/30\" data-kid=\"165\">\n              <div class=\"text-5xl font-black font-heading text-white mb-2\" data-kid=\"166\">$875B</div>\n              <p class=\"text-white/40 font-semibold uppercase text-xs tracking-widest\" data-kid=\"167\">Объём рынка в год</p>\n            </div>\n            <div class=\"relative pl-8 border-l-2 border-white/10\" data-kid=\"168\">\n              <div class=\"text-5xl font-black font-heading text-white mb-2\" data-kid=\"169\">3.5M+</div>\n              <p class=\"text-white/40 font-semibold uppercase text-xs tracking-widest\" data-kid=\"170\">Грузовиков на дорогах</p>\n            </div>\n            <div class=\"relative pl-8 border-l-2 border-white/10\" data-kid=\"171\">\n              <div class=\"text-5xl font-black font-heading text-white mb-2\" data-kid=\"172\">70%</div>\n              <p class=\"text-white/40 font-semibold uppercase text-xs tracking-widest\" data-kid=\"173\">Доля всех грузов США</p>\n            </div>\n          </div>\n\n          <div class=\"mt-20 p-8 glass-panel border-white/5 relative overflow-hidden\" data-kid=\"174\">\n             <img src=\"https://images.unsplash.com/photo-1708807472445-d33589e6b090?q=80&w=1440\" class=\"absolute inset-0 w-full h-full object-cover opacity-20\" alt=\"Dispatcher\" decoding=\"async\" loading=\"lazy\" data-kid=\"175\">\n             <div class=\"relative z-10\" data-kid=\"176\">\n               <p class=\"text-sm italic text-white/60 leading-relaxed\" data-kid=\"177\">\"Логистика — это кровеносная система экономики США. Диспетчер — это мозг этой системы.\"</p>\n               <div class=\"mt-6 flex items-center gap-3\" data-kid=\"178\">\n                 <div class=\"w-10 h-px bg-cyan-500\" data-kid=\"179\"></div>\n                 <span class=\"text-xs font-bold uppercase tracking-widest text-white\" data-kid=\"180\">Industry Standard 2026</span>\n               </div>\n             </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-7 space-y-8\" data-kid=\"181\">\n          <div class=\"p-12 glass-panel border-l-4 border-l-cyan-500 group hover:bg-white/5 transition-all duration-500\" data-kid=\"182\">\n            <div class=\"flex justify-between items-start mb-8\" data-kid=\"183\">\n              <div class=\"w-14 h-14 rounded-xl bg-cyan-500/10 flex items-center justify-center border border-cyan-500/20\" data-kid=\"184\">\n                <i class=\"ti ti-coin text-2xl text-cyan-400\" data-kid=\"185\"></i>\n              </div>\n              <span class=\"text-[10px] font-black text-white/20 uppercase\" data-kid=\"186\">01</span>\n            </div>\n            <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"187\">Высокий доход</h3>\n            <p class=\"text-white/50 leading-relaxed\" data-kid=\"188\">Начальный уровень от $2,000. Опытные специалисты достигают $10,000+ за счет эффективности и масштабирования.</p>\n          </div>\n\n          <div class=\"p-12 glass-panel border-l-4 border-l-blue-500 group hover:bg-white/5 transition-all duration-500\" data-kid=\"189\">\n            <div class=\"flex justify-between items-start mb-8\" data-kid=\"190\">\n              <div class=\"w-14 h-14 rounded-xl bg-blue-500/10 flex items-center justify-center border border-blue-500/20\" data-kid=\"191\">\n                <i class=\"ti ti-world text-2xl text-blue-400\" data-kid=\"192\"></i>\n              </div>\n              <span class=\"text-[10px] font-black text-white/20 uppercase\" data-kid=\"193\">02</span>\n            </div>\n            <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"194\">Полная свобода</h3>\n            <p class=\"text-white/50 leading-relaxed\" data-kid=\"195\">Работайте из любой точки мира. Нужен только ноутбук, стабильный интернет и ваше желание расти.</p>\n          </div>\n\n          <div class=\"p-12 glass-panel border-l-4 border-l-orange-500 group hover:bg-white/5 transition-all duration-500\" data-kid=\"196\">\n            <div clas