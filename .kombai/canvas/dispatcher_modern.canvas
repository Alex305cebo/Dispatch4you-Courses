      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;600;700&family=Montserrat:wght@800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-darker: #070b14;\n    --bg-dark: #0a0e1a;\n    --primary: #06b6d4;\n    --secondary: #0ea5e9;\n    --accent: #f97316;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-darker);\n    color: white;\n    overflow-x: hidden;\n  }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n  }\n\n  .glow-border {\n    position: relative;\n  }\n  .glow-border::after {\n    content: '';\n    position: absolute;\n    inset: -1px;\n    background: linear-gradient(90deg, transparent, var(--primary), transparent);\n    z-index: -1;\n    opacity: 0.3;\n  }\n\n  .pricing-featured {\n    transform: translateY(-20px);\n    background: rgba(6, 182, 212, 0.05);\n    border: 1px solid rgba(6, 182, 212, 0.3);\n  }\n\n  .rotating-border {\n    position: relative;\n    overflow: hidden;\n  }\n  .rotating-border::before {\n    content: '';\n    position: absolute;\n    width: 200%;\n    height: 200%;\n    background: conic-gradient(from 0deg, transparent, var(--primary), transparent 30%, transparent);\n    animation: rotate 4s linear infinite;\n    top: -50%;\n    left: -50%;\n    z-index: 0;\n  }\n  .rotating-border-inner {\n    position: relative;\n    z-index: 1;\n    background: var(--bg-dark);\n    margin: 2px;\n    height: calc(100% - 4px);\n    border-radius: inherit;\n  }\n\n  @keyframes rotate {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n\n  .timeline-wire {\n    width: 2px;\n    background: rgba(6, 182, 212, 0.1);\n    position: absolute;\n    left: 50%;\n    transform: translateX(-50%);\n    height: 100%;\n  }\n  .timeline-fill {\n    width: 2px;\n    background: var(--primary);\n    position: absolute;\n    left: 50%;\n    transform: translateX(-50%);\n    height: 0%;\n    box-shadow: 0 0 15px var(--primary);\n  }\n\n  .marquee-content {\n    animation: marquee 30s linear infinite;\n  }\n  @keyframes marquee {\n    from { transform: translateX(0); }\n    to { transform: translateX(-50%); }\n  }\n</style>\n\n\n<nav class=\"fixed top-0 w-full z-50 glass py-4\" data-kid=\"1\">\n  <div class=\"container mx-auto px-8 flex justify-between items-center\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <img src=\"/logo.svg\" alt=\"Logo\" class=\"h-10\" data-kid=\"4\">\n      <span class=\"text-xl font-bold tracking-tighter uppercase\" data-kid=\"5\">Dispatch<span class=\"text-(--primary)\" data-kid=\"6\">4</span>You</span>\n    </div>\n    <div class=\"hidden md:flex gap-8 text-sm font-semibold tracking-wide uppercase text-white/70\" data-kid=\"7\">\n      <a href=\"#why\" class=\"hover:text-white transition-colors\" data-kid=\"8\">Почему мы</a>\n      <a href=\"#features\" class=\"hover:text-white transition-colors\" data-kid=\"9\">Преимущества</a>\n      <a href=\"#how\" class=\"hover:text-white transition-colors\" data-kid=\"10\">Обучение</a>\n      <a href=\"#pricing\" class=\"hover:text-white transition-colors\" data-kid=\"11\">Тарифы</a>\n    </div>\n    <a href=\"/login.html\" class=\"px-6 py-2 border border-white/20 rounded-full text-sm font-bold hover:bg-white hover:text-black transition-all\" data-kid=\"12\">Вход</a>\n  </div>\n</nav>\n\n\n<section class=\"relative h-screen flex items-center overflow-hidden\" data-kid=\"13\">\n  <video src=\"https://videos.pexels.com/video-files/31842064/13565545_640_360_30fps.mp4\" autoplay muted loop playsinline class=\"absolute top-0 left-0 w-full h-full object-cover z-0\" poster=\"https://images.pexels.com/videos/31842064/pexels-photo-31842064.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" data-kid=\"14\"></video>\n  <div class=\"absolute top-0 left-0 w-full h-full bg-(--bg-darker)/80 z-10\" data-kid=\"15\"></div>\n  \n  <div class=\"container mx-auto px-8 relative z-20\" data-kid=\"16\">\n    <div class=\"max-w-3xl\" data-kid=\"17\">\n      <div class=\"inline-flex items-center gap-2 px-4 py-1 rounded-full border border-(--primary)/40 bg-(--primary)/10 text-(--primary) text-xs font-bold uppercase tracking-widest mb-6 hero-reveal\" data-kid=\"18\">\n        <span class=\"relative flex h-2 w-2\" data-kid=\"19\">\n          <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-(--primary) opacity-75\" data-kid=\"20\"></span>\n          <span class=\"relative inline-flex rounded-full h-2 w-2 bg-(--primary)\" data-kid=\"21\"></span>\n        </span>\n        Набор открыт\n      </div>\n      <h1 class=\"text-6xl md:text-8xl font-black font-montserrat leading-tight mb-6 hero-reveal\" data-kid=\"22\">\n        СТАНЬТЕ <span class=\"bg-gradient-to-r from-(--primary) to-(--secondary) bg-clip-text text-transparent\" data-kid=\"23\">ДИСПЕТЧЕРОМ</span><br data-kid=\"24\">ГРУЗОПЕРЕВОЗОК США\n      </h1>\n      <p class=\"text-xl text-white/70 mb-10 leading-relaxed hero-reveal\" data-kid=\"25\">\n        Элитная подготовка специалистов для современного логистического рынка. <br data-kid=\"26\">Обучение с нуля, практика на реальных кейсах и поддержка 24/7.\n      </p>\n      <div class=\"flex flex-wrap gap-6 items-center hero-reveal\" data-kid=\"27\">\n        <a href=\"#pricing\" class=\"px-10 py-4 bg-(--primary) text-black font-extrabold rounded-sm uppercase tracking-tighter hover:bg-(--secondary) transition-all flex items-center gap-2\" data-kid=\"28\">\n          Начать обучение <i class=\"ti ti-arrow-up-right text-xl\" data-kid=\"29\"></i>\n        </a>\n        <div class=\"flex items-center gap-4 text-sm font-bold text-white/50 border-l border-white/20 pl-6\" data-kid=\"30\">\n          <div class=\"flex text-(--accent)\" data-kid=\"31\">\n            <i class=\"ti ti-star-filled\" data-kid=\"32\"></i><i class=\"ti ti-star-filled\" data-kid=\"33\"></i><i class=\"ti ti-star-filled\" data-kid=\"34\"></i><i class=\"ti ti-star-filled\" data-kid=\"35\"></i><i class=\"ti ti-star-half-filled\" data-kid=\"36\"></i>\n          </div>\n          <span data-kid=\"37\">4.8/5 Рейтинг курса</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<div class=\"py-12 border-y border-white/5 bg-(--bg-darker) overflow-hidden\" data-kid=\"38\">\n  <div class=\"container mx-auto px-8 mb-6\" data-kid=\"39\">\n    <p class=\"text-center text-[10px] font-bold tracking-[0.3em] text-white/30 uppercase\" data-kid=\"40\">Сертифицировано и соответствует стандартам</p>\n  </div>\n  <div class=\"flex whitespace-nowrap marquee-content opacity-30 grayscale contrast-125\" data-kid=\"41\">\n    <div class=\"flex gap-20 px-10 items-center h-12\" data-kid=\"42\">\n      <span class=\"text-2xl font-black italic\" data-kid=\"43\">FMCSA</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"44\">U.S. DOT</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"45\">DAT BOARD</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"46\">TRUCKSTOP</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"47\">IFTA</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"48\">ELOGS</span>\n    </div>\n    <div class=\"flex gap-20 px-10 items-center h-12\" data-kid=\"49\">\n      <span class=\"text-2xl font-black italic\" data-kid=\"50\">FMCSA</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"51\">U.S. DOT</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"52\">DAT BOARD</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"53\">TRUCKSTOP</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"54\">IFTA</span>\n      <span class=\"text-2xl font-black italic\" data-kid=\"55\">ELOGS</span>\n    </div>\n  </div>\n</div>\n\n\n<secti