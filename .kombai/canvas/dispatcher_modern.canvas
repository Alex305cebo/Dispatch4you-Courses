      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;600;700;800&family=Montserrat:wght@800;900&family=JetBrains+Mono:wght@500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-deep: #050505;\n    --primary-cyan: #06b6d4;\n    --primary-blue: #0ea5e9;\n    --accent-orange: #f97316;\n    --glass-border: rgba(6, 182, 212, 0.2);\n    --glass-bg: rgba(255, 255, 255, 0.01);\n  }\n\n  body {\n    background-color: var(--bg-deep);\n    color: #fff;\n    font-family: 'Inter', sans-serif;\n    overflow-x: hidden;\n  }\n\n  /* HUD Grain Texture */\n  .grain-overlay {\n    position: fixed;\n    top: 0; left: 0; width: 100%; height: 100%;\n    background: url('https://grainy-gradients.vercel.app/noise.svg');\n    opacity: 0.03;\n    pointer-events: none;\n    z-index: 50;\n  }\n\n  .fine-grid {\n    background-image: \n      linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .massive-type {\n    font-family: 'Montserrat', sans-serif;\n    line-height: 0.9;\n    letter-spacing: -0.05em;\n    text-transform: uppercase;\n  }\n\n  .mono-data {\n    font-family: 'JetBrains Mono', monospace;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n  }\n\n  /* Rotating Border Animation */\n  @keyframes rotate-border {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n\n  .rotating-border-container {\n    position: relative;\n    padding: 2px;\n    border-radius: 24px;\n    overflow: hidden;\n  }\n\n  .rotating-border-container::before {\n    content: '';\n    position: absolute;\n    top: -50%; left: -50%; width: 200%; height: 200%;\n    background: conic-gradient(transparent, var(--primary-cyan), transparent 30%);\n    animation: rotate-border 4s linear infinite;\n    z-index: 0;\n  }\n\n  .rotating-border-inner {\n    position: relative;\n    z-index: 1;\n    background: var(--bg-deep);\n    border-radius: 22px;\n  }\n\n  .corner-bracket {\n    position: absolute;\n    width: 20px;\n    height: 20px;\n    border: 2px solid var(--primary-cyan);\n    opacity: 0.5;\n  }\n\n  .cb-tl { top: 0; left: 0; border-right: 0; border-bottom: 0; }\n  .cb-tr { top: 0; right: 0; border-left: 0; border-bottom: 0; }\n  .cb-bl { bottom: 0; left: 0; border-right: 0; border-top: 0; }\n  .cb-br { bottom: 0; right: 0; border-left: 0; border-top: 0; }\n\n  .glass-vizor {\n    background: rgba(10, 14, 26, 0.6);\n    backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border);\n    box-shadow: inset 0 0 20px rgba(6, 182, 212, 0.05);\n  }\n\n  /* GSAP Hidden Elements */\n  .reveal { opacity: 0; transform: translateY(30px); }\n</style>\n\n<div class=\"grain-overlay\" data-kid=\"1\"></div>\n\n<main class=\"fine-grid min-h-screen\" data-kid=\"2\">\n  \n  <section class=\"relative min-h-screen flex items-center pt-20\" data-kid=\"3\">\n    <div class=\"container mx-auto px-10 grid grid-cols-12 gap-10 items-center\" data-kid=\"4\">\n      <div class=\"col-span-7 z-10\" data-kid=\"5\">\n        <div class=\"reveal mb-6 flex items-center gap-3\" data-kid=\"6\">\n          <span class=\"px-4 py-1.5 glass-vizor rounded-full text-[11px] font-bold text-cyan-400 mono-data border border-cyan-500/30 flex items-center gap-2\" data-kid=\"7\">\n            <span class=\"w-2 h-2 rounded-full bg-cyan-500 animate-pulse\" data-kid=\"8\"></span>\n            SYSTEM_STATUS: ENROLLMENT_ACTIVE\n          </span>\n        </div>\n        <h1 class=\"massive-type text-[100px] text-white reveal mb-8\" data-kid=\"9\">\n          COMMAND THE <br data-kid=\"10\">\n          <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-600\" data-kid=\"11\">SUPPLY CHAIN</span>\n        </h1>\n        <p class=\"text-xl text-slate-400 max-w-xl reveal mb-10 leading-relaxed font-light\" data-kid=\"12\">\n          Elite dispatcher training for the modern logistics landscape. Master the simulator, dominate the load boards, and scale your career in the US trucking industry.\n        </p>\n        <div class=\"flex items-center gap-6 reveal\" data-kid=\"13\">\n          <a href=\"#pricing\" class=\"group relative px-10 py-5 bg-cyan-500 text-black font-bold uppercase tracking-widest text-sm transition-all hover:bg-white flex items-center gap-3\" data-kid=\"14\">\n            INITIALIZE TRAINING\n            <i class=\"ti ti-arrow-up-right transition-transform group-hover:translate-x-1 group-hover:-translate-y-1\" data-kid=\"15\"></i>\n          </a>\n          <a href=\"#how-it-works\" class=\"text-white/60 hover:text-cyan-400 transition-colors mono-data text-xs flex items-center gap-2\" data-kid=\"16\">\n            <i class=\"ti ti-binary\" data-kid=\"17\"></i> VIEW_Syllabus.sh\n          </a>\n        </div>\n      </div>\n      \n      <div class=\"col-span-5 relative\" data-kid=\"18\">\n        <div class=\"reveal relative glass-vizor p-4 rounded-3xl overflow-hidden shadow-2xl shadow-cyan-500/10\" data-kid=\"19\">\n          <div class=\"corner-bracket cb-tl\" data-kid=\"20\"></div>\n          <div class=\"corner-bracket cb-tr\" data-kid=\"21\"></div>\n          <div class=\"corner-bracket cb-bl\" data-kid=\"22\"></div>\n          <div class=\"corner-bracket cb-br\" data-kid=\"23\"></div>\n          <div class=\"relative aspect-square rounded-2xl overflow-hidden border border-white/5 bg-slate-900\" data-kid=\"24\">\n            <video src=\"https://videos.pexels.com/video-files/34342557/14549187_640_360_30fps.mp4\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-60 mix-blend-screen\" data-kid=\"25\"></video>\n            <div class=\"absolute inset-0 bg-gradient-to-t from-bg-deep/80 via-transparent to-transparent\" data-kid=\"26\"></div>\n            \n            <div class=\"absolute top-6 left-6 mono-data text-[10px] text-cyan-400/70 space-y-1\" data-kid=\"27\">\n              <div data-kid=\"28\">LAT: 37.0902</div>\n              <div data-kid=\"29\">LONG: -95.7129</div>\n              <div data-kid=\"30\">MAP_NODE: ACTIVE</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"border-y border-white/5 py-10 overflow-hidden reveal\" data-kid=\"31\">\n    <div class=\"flex items-center gap-10 opacity-30 grayscale hover:opacity-100 transition-opacity\" data-kid=\"32\">\n      <div class=\"mono-data text-xs text-white/50 px-10 border-r border-white/10 shrink-0\" data-kid=\"33\">REGULATORY_COMPLIANCE</div>\n      <div class=\"flex gap-20 animate-marquee whitespace-nowrap\" data-kid=\"34\">\n        <span class=\"text-2xl font-black italic tracking-tighter\" data-kid=\"35\">FMCSA</span>\n        <span class=\"text-2xl font-black italic tracking-tighter\" data-kid=\"36\">U.S. DOT</span>\n        <span class=\"text-2xl font-black italic tracking-tighter\" data-kid=\"37\">DAT FREIGHT</span>\n        <span class=\"text-2xl font-black italic tracking-tighter\" data-kid=\"38\">TRUCKSTOP</span>\n        <span class=\"text-2xl font-black italic tracking-tighter\" data-kid=\"39\">FMCSA</span>\n        <span class=\"text-2xl font-black italic tracking-tighter\" data-kid=\"40\">U.S. DOT</span>\n      </div>\n    </div>\n  </div>\n\n  \n  <section class=\"py-32\" data-kid=\"41\">\n    <div class=\"container mx-auto px-10\" data-kid=\"42\">\n      <div class=\"flex justify-between items-end mb-20 reveal\" data-kid=\"43\">\n        <div data-kid=\"44\">\n          <span class=\"mono-data text-cyan-400 text-xs mb-4 block\" data-kid=\"45\">WHY_DISPATCH4YOU</span>\n          <h2 class=\"massive-type text-6xl text-white\" data-kid=\"46\">THE ELITE STANDARD</h2>\n        </div>\n        <div class=\"text-right mono-data text-[10px] text-white/30\" data-kid=\"47\">\n          SEC_02 // CLOSED_COMMUNITY_PROTOCOL\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-3 gap-0 border border-white/10 glass-vizor\" data-kid=\"48\">\n        <div class=\"p-12 border-r border-white/10 reveal group hover:bg-cyan-500/5 transition-colors\" data-kid=\"49\">\n          <i class=\"ti ti-cpu text-4xl text-cyan-400 mb-8 block\" data-kid=\"50\"></i>\n          <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"51\">AI PRACTICE</h3>\n          <p class=\"text-slate-400 leading-relaxed font-light\" data-kid=\"52\">Train negotiations with AI-simulated brokers. 50+ real-world scenarios enabled.</p>\n          <div class=\"mt-10 pt-10 border-t border-white/5 mono-data text-xs text-cyan-400/60\" data-kid=\"53\">+120 OPERATORS CERTIFIED</div>\n        </div>\n        <div class=\"p-12 border-r border-white/10 reveal group hover:bg-orange-500/5 transition-colors\" data-kid=\"54\">\n          <i class=\"ti ti-headset text-4xl text-orange-400 mb-8 block\" data-kid=\"55\"></i>\n          <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"56\">24/7 SUPPORT</h3>\n          <p class=\"text-slate-400 leading-relaxed font-light\" data-kid=\"57\">Direct line to senior dispatchers. Error analysis and live chat assistance.</p>\n          <div class=\"mt-10 pt-10 border-t border-white/5 mono-data text-xs text-orange-400/60\" data-kid=\"58\">AVG_RESPONSE_TIME: 15M</div>\n        </div>\n        <div class=\"p-12 reveal group hover:bg-blue-500/5 transition-colors\" data-kid=\"59\">\n          <i class=\"ti ti-trending-up text-4xl text-blue-400 mb-8 block\" data-kid=\"60\"></i>\n          <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"61\">CAREER ENGINE</h3>\n          <p class=\"text-slate-400 leading-relaxed font-light\" data-kid=\"62\">Resume optimization, interview prep, and exclusive US job board access.</p>\n          <div class=\"mt-10 pt-10 border-t border-white/5 mono-data text-xs text-blue-400/60\" data-kid=\"63\">PLACEMENT_RATE: 87%</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-20 reveal\" data-kid=\"64\">\n    <div class=\"container mx-auto px-10\" data-kid=\"65\">\n      <div class=\"relative aspect-[21/9] rounded-[40px] overflow-hidden border border-white/10 group\" data-kid=\"66\">\n        <video src=\"https://videos.pexels.com/video-files/34342926/14549300_360_640_30fps.mp4\" autoplay muted loop playsinline class=\"w-full h-full object-cover scale-110 group-hover:scale-100 transition-transform duration-1000\" data-kid=\"67\"></video>\n        <div class=\"absolute inset-0 bg-black/40 backdrop-blur-[2px]\" data-kid=\"68\"></div>\n        <div class=\"absolute inset-0 flex flex-col items-center justify-center text-center p-20\" data-kid=\"69\">\n          <div class=\"mono-data text-xs text-cyan-400 mb-6 px-4 py-1 border border-cyan-400/30 rounded-full\" data-kid=\"70\">SIMULATION_ACTIVE</div>\n          <h2 class=\"massive-type text-7xl text-white mb-8\" data-kid=\"71\">USA MAP TRAINER</h2>\n          <p class=\"text-xl font-light text-white/70 max-w-2xl mb-10\" data-kid=\"72\">Interactive state mastery and route optimization simulator. Real-time geodata tracking.</p>\n          <button class=\"px-12 py-4 border border-white text-white font-bold tracking-widest hover:bg-white hover:text-black transition-all\" data-kid=\"73\">ACCESS_SIMULATOR.exe</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32\" data-kid=\"74\">\n    <div class=\"container mx-auto px-10 grid grid-cols-12 gap-20 items-center\" data-kid=\"75\">\n      <div class=\"col-span-5 reveal\" data-kid=\"76\">\n        <div class=\"sticky top-40\" data-kid=\"77\">\n          <span class=\"mono-data text-orange-400 text-xs mb-4 block\" data-kid=\"78\">MARKET_INTELLIGENCE</span>\n          <h2 class=\"massive-type text-6xl text-white mb-8\" data-kid=\"79\">WHY DISPATCH?</h2>\n          <p class=\"text-slate-400 font-light mb-12\" data-kid=\"80\">The foundation of the US economy. Stable income, global mobility, and exponential growth potential.</p>\n          \n          <div class=\"space-y-6\" data-kid=\"81\">\n            <div class=\"p-6 glass-vizor border-l-4 border-cyan-500 rounded-r-2xl\" data-kid=\"82\">\n              <div class=\"text-4xl font-black massive-type mb-1\" data-kid=\"83\">$875B</div>\n              <div class=\"mono-data text-[10px] text-white/40\" data-kid=\"84\">ANNUAL_MARKET_CAP</div>\n            </div>\n            <div class=\"p-6 glass-vizor border-l-4 border-orange-500 rounded-r-2xl\" data-kid=\"85\">\n              <div class=\"text-4xl font-black massive-type mb-1\" data-kid=\"86\">3.5M+</div>\n              <div class=\"mono-data text-[10px] text-white/40\" data-kid=\"87\">ACTIVE_CARRIERS</div>\n            </div>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"col-span-7 space-y-6\" data-kid=\"88\">\n        <div class=\"reveal glass-vizor p-10 rounded-3xl hover:border-cyan-500/50 transition-all flex items-start gap-8\" data-kid=\"89\">\n          <div class=\"w-16 h-16 rounded-2xl bg-cyan-500/10 flex items-center justify-center text-cyan-400 text-2xl border border-cyan-500/20\" data-kid=\"90\">\n            <i class=\"ti ti-currency-dollar\" data-kid=\"91\"></i>\n          </div>\n          <div data-kid=\"92\">\n            <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"93\">HIGH REVENUE</h3>\n            <p class=\"text-slate-400 font-light\" data-kid=\"94\">Stable USD-based earnings with uncapped commission potential based on fleet performance.</p>\n          </div>\n        </div>\n        <div class=\"reveal glass-vizor p-10 rounded-3xl hover:border-blue-500/50 transition-all flex items-start gap-8\" data-kid=\"95\">\n          <div class=\"w-16 h-16 rounded-2xl bg-blue-500/10 flex items-center justify-center text-blue-400 text-2xl border border-blue-500/20\" data-kid=\"96\">\n            <i class=\"ti ti-world\" data-kid=\"97\"></i>\n          </div>\n          <div data-kid=\"98\">\n            <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"99\">REMOTE FREEDOM</h3>\n            <p class=\"text-slate-400 font-light\" data-kid=\"100\">Operate from any global coordinate. All you need is high-speed data and a terminal.</p>\n          </div>\n        </div>\n        <div class=\"reveal glass-vizor p-10 rounded-3xl hover:border-orange-500/50 transition-all flex items-start gap-8\" data-kid=\"101\">\n          <div class=\"w-16 h-16 rounded-2xl bg-orange-500/10 flex items-center justify-center text-orange-400 text-2xl border border-orange-500/20\" data-kid=\"102\">\n            <i class=\"ti ti-clock\" data-kid=\"103\"></i>\n          </div>\n          <div data-kid=\"104\">\n            <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"105\">FLEXIBLE SHIFTS</h3>\n            <p class=\"text-slate-400 font-light\" data-kid=\"106\">Control your workflow. 4-6 hour specialized shifts or full-day operation management.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-[#070b14]/50 relative overflow-hidden\" id=\"how-it-works\" data-kid=\"107\">\n    <div class=\"container mx-auto px-10\" data-kid=\"108\">\n      <div class=\"text-center mb-32 reveal\" data-kid=\"109\">\n        <span class=\"mono-data text-cyan-400 text-xs mb-4 block\" data-kid=\"110\">EXECUTION_PATH</span>\n        <h2 class=\"massive-type text-7xl text-white\" data-kid=\"111\">THE JOURNEY</h2>\n      </div>\n\n      <div class=\"relative max-w-4xl mx-auto\" data-kid=\"112\">\n        \n        <div class=\"absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] bg-white/5\" data-kid=\"113\">\n          <div id=\"wire-fill\" class=\"w-full bg-gradient-to-b from-cyan-400 to-blue-600 shadow-[0_0_15px_rgba(6,182,212,0.8)] h-0\" data-kid=\"114\"></div>\n        </div>\n\n        \n        <div class=\"space-y-40 relative\" data-kid=\"115\">\n          <div class=\"flex items-center reveal\" data-kid=\"116\">\n            <div class=\"w-1/2 pr-20 text-right\" data-kid=\"117\">\n              <div class=\"mono-data text-cyan-400 text-sm mb-2\" data-kid=\"118\">PHASE_01</div>\n              <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"119\">IMMERSION</h3>\n              <p class=\"text-slate-400 font-light\" data-kid=\"120\">System foundations, US market landscape, and regulatory FMCSA/DOT compliance.</p>\n            </div>\n            <div class=\"w-10 h-10 rounded-full glass-vizor border-2 border-cyan-400 z-10 flex items-center justify-center bg-bg-deep text-xs font-bold text-cyan-400\" data-kid=\"121\">1</div>\n            <div class=\"w-1/2 pl-20\" data-kid=\"122\"></div>\n          </div>\n\n          <div class=\"flex items-center flex-row-reverse reveal\" data-kid=\"123\">\n            <div class=\"w-1/2 pl-20 text-left\" data-kid=\"124\">\n              <div class=\"mono-data text-blue-400 text-sm mb-2\" data-kid=\"125\">PHASE_02</div>\n              <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"126\">TOOLSET</h3>\n              <p class=\"text-slate-400 font-light\" data-kid=\"127\">Load Board mastery, rate reading, and advanced document processing (BOL/POD).</p>\n            </div>\n            <div class=\"w-10 h-10 rounded-full glass-vizor border-2 border-blue-400 z-10 flex items-center justify-center bg-bg-deep text-xs font-bold text-blue-400\" data-kid=\"128\">2</div>\n            <div class=\"w-1/2 pr-20\" data-kid=\"129\"></div>\n          </div>\n\n          <div class=\"flex items-center reveal\" data-kid=\"130\">\n            <div class=\"w-1/2 pr-20 text-right\" data-kid=\"131\">\n              <div class=\"mono-data text-cyan-400 text-sm mb-2\" data-kid=\"132\">PHASE_03</div>\n              <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"133\">EXECUTION</h3>\n              <div class=\"text-slate-400 font-light\" data-kid=\"134\">AI-simulated negotiations and high-pressure decision making quizes.</div>\n            </div>\n            <div class=\"w-10 h-10 rounded-full glass-vizor border-2 border-cyan-400 z-10 flex items-center justify-center bg-bg-deep text-xs font-bold text-cyan-400\" data-kid=\"135\">3</div>\n            <div class=\"w-1/2 pl-20\" data-kid=\"136\"></div>\n          </div>\n\n          <div class=\"flex items-center flex-row-reverse reveal\" data-kid=\"137\">\n            <div class=\"w-1/2 pl-20 text-left\" data-kid=\"138\">\n              <div class=\"mono-data text-orange-400 text-sm mb-2\" data-kid=\"139\">PHASE_04</div>\n              <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"140\">PRACTICE</h3>\n              <p class=\"text-slate-400 font-light\" data-kid=\"141\">300+ real-world case studies and complex problem-solving on the road.</p>\n            </div>\n            <div class=\"w-10 h-10 rounded-full glass-vizor border-2 border-orange-400 z-10 flex items-center justify-center bg-bg-deep text-xs font-bold text-orange-400\" data-kid=\"142\">4</div>\n            <div class=\"w-1/2 pr-20\" data-kid=\"143\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40\" id=\"pricing\" data-kid=\"144\">\n    <div class=\"container mx-auto px-10\" data-kid=\"145\">\n      <div class=\"text-center mb-20 reveal\" data-kid=\"146\">\n        <span class=\"mono-data text-cyan-400 text-xs mb-4 block\" data-kid=\"147\">ACCESS_TIERS</span>\n        <h2 class=\"massive-type text-7xl text-white\" data-kid=\"148\">THE ACADEMY</h2>\n      </div>\n\n      <div class=\"grid grid-cols-3 gap-8\" data-kid=\"149\">\n        <div class=\"reveal p-10 glass-vizor rounded-3xl border-white/5 flex flex-col h-full\" data-kid=\"150\">\n          <div class=\"mono-data text-xs text-white/40 mb-10\" data-kid=\"151\">01_CORE</div>\n          <h3 class=\"text-4xl font-bold mb-2\" data-kid=\"152\">BASIC</h3>\n          <div class=\"text-5xl font-black massive-type text-white/30 mb-8\" data-kid=\"153\">FREE</div>\n          <ul class=\"space-y-4 mb-10 flex-grow mono-data text-[11px] text-white/50\" data-kid=\"154\">\n            <li class=\"flex items-center gap-2\" data-kid=\"155\"><i class=\"ti ti-check text-cyan-400\" data-kid=\"156\"></i> 3_CORE_MODULES</li>\n            <li class=\"flex items-center gap-2\" data-kid=\"157\"><i class=\"ti ti-check text-cyan-400\" data-kid=\"158\"></i> DOC_TEMPLATES</li>\n            <li class=\"flex items-center gap-2 text-white/20\" data-kid=\"159\"><i class=\"ti ti-x\" data-kid=\"160\"></i> AI_SIMULATOR</li>\n            <li class=\"flex items-center gap-2 text-white/20\" data-kid=\"161\"><i class=\"ti ti-x\" data-kid=\"162\"></i> MENTOR_CHANNELS</li>\n          </ul>\n          <button class=\"w-full py-4 border border-white/10 text-white font-bold tracking-widest hover:bg-white hover:text-black transition-all\" data-kid=\"163\">INITIALIZE.sh</button>\n        </div>\n\n        <div class=\"reveal rotating-border-container shadow-[0_0_50px_rgba(6,182,212,0.2)]\" data-kid=\"164\">\n          <div class=\"rotating-border-inner p-10 flex flex-col h-full\" data-kid=\"165\">\n            <div class=\"flex justify-between items-start mb-10\" data-kid=\"166\">\n              <div class=\"mono-data text-xs text-cyan-400\" data-kid=\"167\">02_STANDARD</div>\n              <span class=\"px-3 py-1 bg-cyan-500/20 text-cyan-400 rounded-full text-[9px] mono-data font-bold\" data-kid=\"168\">RECOMMENDED</span>\n            </div>\n            <h3 class=\"text-4xl font-bold mb-2\" data-kid=\"169\">FULL ACCESS</h3>\n            <div class=\"text-5xl font-black massive-type text-cyan-400 mb-8\" data-kid=\"170\">$1,000</div>\n            <ul class=\"space-y-4 mb-10 flex-grow mono-data text-[11px] text-white/70\" data-kid=\"171\">\n              <li class=\"flex items-center gap-2\" data-kid=\"172\"><i class=\"ti ti-check text-cyan-400\" data-kid=\"173\"></i> ALL_15_MODULES</li>\n              <li class=\"flex items-center gap-2\" data-kid=\"174\"><i class=\"ti ti-check text-cyan-400\" data-kid=\"175\"></i> AI