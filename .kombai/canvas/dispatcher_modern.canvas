      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;600;700;800;900&family=Space+Grotesk:wght@300;500;700&display=swap');\n\n  :root {\n    --bg-void: #050505;\n    --grid-color: rgba(6, 182, 212, 0.1);\n    --primary: #06b6d4;\n    --accent: #f97316;\n    --slate-text: #94a3b8;\n  }\n\n  body {\n    background-color: var(--bg-void);\n    color: white;\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-mono-tech {\n    font-family: 'Space Grotesk', sans-serif;\n  }\n\n  .massive-type {\n    font-weight: 900;\n    letter-spacing: -0.04em;\n    line-height: 0.9;\n    text-transform: uppercase;\n  }\n\n  .grid-overlay {\n    background-image: \n      linear-gradient(to right, var(--grid-color) 1px, transparent 1px),\n      linear-gradient(to bottom, var(--grid-color) 1px, transparent 1px);\n    background-size: 60px 60px;\n    mask-image: radial-gradient(circle at center, black, transparent 80%);\n  }\n\n  .glass-vizor {\n    background: rgba(255, 255, 255, 0.02);\n    backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    box-shadow: inset 0 0 0 1px rgba(6, 182, 212, 0.05);\n  }\n\n  .noise-texture {\n    position: absolute;\n    inset: 0;\n    opacity: 0.03;\n    pointer-events: none;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  }\n\n  .premium-glow {\n    background: radial-gradient(1000px circle at center, rgba(249, 115, 22, 0.15), transparent 70%);\n  }\n\n  .btn-elite {\n    background: white;\n    color: black;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    padding: 1rem 2.5rem;\n    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .btn-elite:hover {\n    background: var(--primary);\n    color: white;\n    transform: scale(1.05);\n  }\n\n  .timeline-path {\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n  }\n</style>\n\n<div class=\"relative min-h-screen\" data-kid=\"1\">\n  \n  <div class=\"fixed inset-0 grid-overlay pointer-events-none z-0\" data-kid=\"2\"></div>\n\n  \n  <section class=\"relative h-screen flex flex-col justify-end p-12 overflow-hidden\" data-kid=\"3\">\n    <div class=\"absolute inset-0 z-0\" data-kid=\"4\">\n      <video class=\"w-full h-full object-cover grayscale brightness-50 opacity-40\" src=\"https://videos.pexels.com/video-files/35907900/15231598_640_360_25fps.mp4\" autoplay muted loop playsinline poster=\"https://images.pexels.com/videos/35907900/pexels-photo-35907900.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" data-kid=\"5\">\n      </video>\n      <div class=\"absolute inset-0 bg-linear-to-t from-black via-transparent to-transparent\" data-kid=\"6\"></div>\n    </div>\n\n    <div class=\"relative z-10 max-w-7xl w-full mx-auto\" data-kid=\"7\">\n      <div class=\"inline-flex items-center gap-3 px-4 py-2 rounded-full border border-[var(--primary)] bg-[var(--primary)]/10 text-[var(--primary)] font-bold text-xs uppercase tracking-widest mb-8 reveal-y\" data-kid=\"8\">\n        <span class=\"w-2 h-2 rounded-full bg-[var(--primary)] animate-pulse\" data-kid=\"9\"></span>\n        Набор открыт • Session Active\n      </div>\n      \n      <h1 class=\"massive-type text-7xl md:text-[120px] mb-8 leading-none reveal-split\" data-kid=\"10\">\n        Global Logistics <br data-kid=\"11\">\n        <span class=\"text-[var(--primary)]\" data-kid=\"12\">Academy</span>\n      </h1>\n\n      <div class=\"flex flex-col md:flex-row items-start md:items-center gap-12 mt-12\" data-kid=\"13\">\n        <div class=\"max-w-xl reveal-y\" data-kid=\"14\">\n          <p class=\"text-xl text-slate-400 font-light leading-relaxed\" data-kid=\"15\">\n            Elite dispatcher training for the modern supply chain landscape. \n            Command global shipping routes from anywhere in the world.\n          </p>\n        </div>\n        \n        <div class=\"flex gap-6 reveal-y\" data-kid=\"16\">\n          <button class=\"btn-elite rounded-sm\" data-kid=\"17\">Enroll Now</button>\n          <button class=\"px-8 py-4 border border-white/10 hover:border-white/30 transition-colors uppercase tracking-widest text-xs font-bold\" data-kid=\"18\">View Syllabus</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-32 px-12 border-y border-white/5 bg-black/40\" data-kid=\"19\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"20\">\n      <div class=\"mb-24\" data-kid=\"21\">\n        <span class=\"text-[var(--primary)] font-mono-tech uppercase tracking-[0.3em] text-xs\" data-kid=\"22\">Why The Academy</span>\n        <h2 class=\"text-5xl font-bold mt-4\" data-kid=\"23\">Professional Infrastructure</h2>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-0 border border-white/10\" data-kid=\"24\">\n        \n        <div class=\"p-12 border-r border-b border-white/10 group hover:bg-white/[0.02] transition-colors\" data-kid=\"25\">\n          <span class=\"font-mono-tech text-[var(--primary)] text-6xl block mb-6 counter\" data-target=\"120\" data-kid=\"26\">0</span>\n          <h3 class=\"text-lg font-bold mb-4 uppercase tracking-tighter\" data-kid=\"27\">AI-Simulated Calls</h3>\n          <p class=\"text-slate-500 text-sm leading-relaxed\" data-kid=\"28\">High-fidelity negotiation training with broker simulation engines.</p>\n        </div>\n        \n        <div class=\"p-12 border-r border-b border-white/10 group hover:bg-white/[0.02] transition-colors\" data-kid=\"29\">\n          <span class=\"font-mono-tech text-[var(--accent)] text-6xl block mb-6 counter\" data-target=\"87\" data-kid=\"30\">0</span>\n          <h3 class=\"text-lg font-bold mb-4 uppercase tracking-tighter\" data-kid=\"31\">Placement Rate %</h3>\n          <p class=\"text-slate-500 text-sm leading-relaxed\" data-kid=\"32\">Certified graduates securing career opportunities within 60 days.</p>\n        </div>\n        \n        <div class=\"p-12 border-r border-b border-white/10 group hover:bg-white/[0.02] transition-colors md:col-span-2 relative overflow-hidden\" data-kid=\"33\">\n          <img src=\"https://images.pexels.com/photos/5833758/pexels-photo-5833758.jpeg?auto=compress&cs=tinysrgb&w=800\" class=\"absolute inset-0 w-full h-full object-cover opacity-20 grayscale transition-transform duration-700 group-hover:scale-110\" loading=\"lazy\" decoding=\"async\" data-kid=\"34\">\n          <div class=\"relative z-10\" data-kid=\"35\">\n            <span class=\"font-mono-tech text-white text-6xl block mb-6\" data-kid=\"36\">24/7</span>\n            <h3 class=\"text-lg font-bold mb-4 uppercase tracking-tighter\" data-kid=\"37\">Mission Control</h3>\n            <p class=\"text-slate-300 text-sm leading-relaxed max-w-xs\" data-kid=\"38\">Direct encrypted channel to active logistics experts and tactical mentors.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-32 bg-black\" data-kid=\"39\">\n    <div class=\"max-w-7xl mx-auto px-12 mb-16\" data-kid=\"40\">\n      <div class=\"flex justify-between items-end\" data-kid=\"41\">\n        <div data-kid=\"42\">\n          <span class=\"text-[var(--accent)] font-mono-tech uppercase tracking-[0.3em] text-xs\" data-kid=\"43\">Curriculum</span>\n          <h2 class=\"text-5xl font-bold mt-4\" data-kid=\"44\">Module Ecosystem</h2>\n        </div>\n        <div class=\"flex gap-4\" data-kid=\"45\">\n          <button class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center hover:bg-white hover:text-black transition-all\" data-kid=\"46\">←</button>\n          <button class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center hover:bg-white hover:text-black transition-all\" data-kid=\"47\">→</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"flex gap-8 overflow-hidden px-12 pb-12 cursor-grab active:cursor-grabbing\" id=\"feature-strip\" data-kid=\"48\">\n      \n      <div class=\"min-w-[400px] aspect-[4/5] glass-vizor p-12 relative flex flex-col justify-end group transition-all duration-500 hover:translate-y-[-10px]\" data-kid=\"49\">\n        <div class=\"noise-texture\" data-kid=\"50\"></div>\n        <div class=\"absolute top-12 left-12 w-12 h-12 border border-[var(--primary)]/30 rounded-lg flex items-center justify-center group-hover:bg-[var(--primary)] group-hover:text-white transition-all\" data-kid=\"51\">\n          <i class=\"ti ti-book-2 text-2xl\" data-kid=\"52\"></i>\n        </div>\n        <div class=\"absolute top-12 right-12 font-mono-tech text-white/10 text-8xl leading-none tracking-tighter\" data-kid=\"53\">01</div>\n        <div class=\"relative z-10\" data-kid=\"54\">\n          <h3 class=\"text-3xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"55\">Technical Ops</h3>\n          <p class=\"text-slate-400 leading-relaxed\" data-kid=\"56\">Mastering rate confirmations, BOL structures, and regulatory DOT frameworks.</p>\n          <div class=\"mt-8 pt-8 border-t border-white/5 flex justify-between items-center opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"57\">\n            <span class=\"text-xs uppercase font-bold tracking-widest text-[var(--primary)]\" data-kid=\"58\">Explore Module</span>\n            <i class=\"ti ti-arrow-right\" data-kid=\"59\"></i>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"min-w-[400px] aspect-[4/5] glass-vizor p-12 relative flex flex-col justify-end group transition-all duration-500 hover:translate-y-[-10px]\" data-kid=\"60\">\n        <div class=\"noise-texture\" data-kid=\"61\"></div>\n        <div class=\"absolute top-12 left-12 w-12 h-12 border border-[var(--accent)]/30 rounded-lg flex items-center justify-center group-hover:bg-[var(--accent)] group-hover:text-white transition-all\" data-kid=\"62\">\n          <i class=\"ti ti-cpu text-2xl\" data-kid=\"63\"></i>\n        </div>\n        <div class=\"absolute top-12 right-12 font-mono-tech text-white/10 text-8xl leading-none tracking-tighter\" data-kid=\"64\">02</div>\n        <div class=\"relative z-10\" data-kid=\"65\">\n          <h3 class=\"text-3xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"66\">AI Simulation</h3>\n          <p class=\"text-slate-400 leading-relaxed\" data-kid=\"67\">Live voice training with brokers using neural NLP behavioral models.</p>\n          <div class=\"mt-8 pt-8 border-t border-white/5 flex justify-between items-center opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"68\">\n            <span class=\"text-xs uppercase font-bold tracking-widest text-[var(--accent)]\" data-kid=\"69\">Explore Module</span>\n            <i class=\"ti ti-arrow-right\" data-kid=\"70\"></i>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"min-w-[400px] aspect-[4/5] glass-vizor p-12 relative flex flex-col justify-end group transition-all duration-500 hover:translate-y-[-10px]\" data-kid=\"71\">\n        <div class=\"noise-texture\" data-kid=\"72\"></div>\n        <div class=\"absolute top-12 left-12 w-12 h-12 border border-white/10 rounded-lg flex items-center justify-center group-hover:bg-white group-hover:text-black transition-all\" data-kid=\"73\">\n          <i class=\"ti ti-bar-chart text-2xl\" data-kid=\"74\"></i>\n        </div>\n        <div class=\"absolute top-12 right-12 font-mono-tech text-white/10 text-8xl leading-none tracking-tighter\" data-kid=\"75\">03</div>\n        <div class=\"relative z-10\" data-kid=\"76\">\n          <h3 class=\"text-3xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"77\">Market Analysis</h3>\n          <p class=\"text-slate-400 leading-relaxed\" data-kid=\"78\">Real-time load board mastery and spot market rate trajectory prediction.</p>\n          <div class=\"mt-8 pt-8 border-t border-white/5 flex justify-between items-center opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"79\">\n            <span class=\"text-xs uppercase font-bold tracking-widest\" data-kid=\"80\">Explore Module</span>\n            <i class=\"ti ti-arrow-right\" data-kid=\"81\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative h-[600px] flex items-center justify-center overflow-hidden\" data-kid=\"82\">\n    <video class=\"absolute inset-0 w-full h-full object-cover opacity-60 scale-110 parallax-video\" src=\"https://videos.pexels.com/video-files/34342926/14549300_360_640_30fps.mp4\" autoplay muted loop playsinline data-kid=\"83\">\n    </video>\n    <div class=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" data-kid=\"84\"></div>\n    <div class=\"relative z-10 text-center max-w-3xl px-12\" data-kid=\"85\">\n      <h2 class=\"massive-type text-6xl mb-8\" data-kid=\"86\">Tactical Map Simulator</h2>\n      <p class=\"text-xl text-slate-300 font-light mb-12\" data-kid=\"87\">Train on the exact topography of North American shipping routes with our proprietary geographic simulation engine.</p>\n      <a href=\"map-trainer/\" class=\"inline-block border-b-2 border-[var(--primary)] pb-2 uppercase tracking-[0.4em] text-sm font-black hover:text-[var(--primary)] transition-colors\" data-kid=\"88\">Initiate Training System →</a>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-32 bg-black border-t border-white/5\" data-kid=\"89\">\n    <div class=\"max-w-7xl mx-auto px-12\" data-kid=\"90\">\n      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-24 items-start\" data-kid=\"91\">\n        <div class=\"sticky top-32\" data-kid=\"92\">\n          <span class=\"text-[var(--primary)] font-mono-tech uppercase tracking-[0.3em] text-xs\" data-kid=\"93\">Industry Scale</span>\n          <h2 class=\"massive-type text-6xl mt-4 mb-12\" data-kid=\"94\">The Future of <br data-kid=\"95\">Freight Command</h2>\n          \n          <div class=\"space-y-12\" data-kid=\"96\">\n            <div class=\"flex items-center gap-8 border-l-2 border-[var(--primary)] pl-8 py-4\" data-kid=\"97\">\n              <span class=\"font-mono-tech text-6xl text-white counter\" data-target=\"875\" data-suffix=\"B\" data-prefix=\"$\" data-kid=\"98\">$0B</span>\n              <p class=\"text-slate-400 uppercase tracking-widest text-xs font-bold leading-tight\" data-kid=\"99\">Annual Market <br data-kid=\"100\">Velocity</p>\n            </div>\n            <div class=\"flex items-center gap-8 border-l-2 border-white/10 pl-8 py-4\" data-kid=\"101\">\n              <span class=\"font-mono-tech text-6xl text-white counter\" data-target=\"3.5\" data-suffix=\"M+\" data-decimal=\"1\" data-kid=\"102\">0.0M+</span>\n              <p class=\"text-slate-400 uppercase tracking-widest text-xs font-bold leading-tight\" data-kid=\"103\">Operational <br data-kid=\"104\">Heavy Assets</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"space-y-8\" data-kid=\"105\">\n          <div class=\"glass-vizor p-12 rounded-sm group transition-colors hover:bg-white/[0.03]\" data-kid=\"106\">\n            <h3 class=\"text-2xl font-bold mb-4 flex items-center gap-4\" data-kid=\"107\">\n              <span class=\"text-[var(--primary)]\" data-kid=\"108\">01</span> Global Freedom\n            </h3>\n            <p class=\"text-slate-400 leading-relaxed\" data-kid=\"109\">Operation command is location-independent. Control the flow of goods across continents from any connected digital node.</p>\n          </div>\n          <div class=\"glass-vizor p-12 rounded-sm group transition-colors hover:bg-white/[0.03]\" data-kid=\"110\">\n            <h3 class=\"text-2xl font-bold mb-4 flex items-center gap-4\" data-kid=\"111\">\n              <span class=\"text-[var(--primary)]\" data-kid=\"112\">02</span> Economic Resistance\n            </h3>\n            <p class=\"text-slate-400 leading-relaxed\" data-kid=\"113\">Freight is the lifeblood of economy. Logistics remains critical even in volatile markets, ensuring career stability.</p>\n          </div>\n          <div class=\"glass-vizor p-12 rounded-sm group transition-colors hover:bg-white/[0.03]\" data-kid=\"114\">\n            <h3 class=\"text-2xl font-bold mb-4 flex items-center gap-4\" data-kid=\"115\">\n              <span class=\"text-[var(--primary)]\" data-kid=\"116\">03</span> Scalable Income\n            </h3>\n            <p class=\"text-slate-400 leading-relaxed\" data-kid=\"117\">Elite dispatchers operate on efficiency commissions. Your earnings correlate directly with your tactical performance.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-32 overflow-hidden bg-[var(--bg-void)]\" data-kid=\"118\">\n    <div class=\"max-w-7xl mx-auto px-12 mb-24\" data-kid=\"119\">\n        <span class=\"text-[var(--accent)] font-mono-tech uppercase tracking-[0.3em] text-xs\" data-kid=\"120\">The Route</span>\n        <h2 class=\"text-5xl font-bold mt-4\" data-kid=\"121\">Training Trajectory</h2>\n    </div>\n\n    <div class=\"relative\" data-kid=\"122\">\n      <div class=\"absolute top-1/2 left-0 w-full h-[2px] bg-white/5 -translate-y-1/2\" data-kid=\"123\">\n        <div class=\"h-full bg-linear-to-r from-[var(--primary)] to-[var(--accent)] w-0\" id=\"timeline-scroll-progress\" data-kid=\"124\"></div>\n      </div>\n\n      <div class=\"max-w-7xl mx-auto px-12 relative flex justify-between\" data-kid=\"125\">\n        <div class=\"timeline-step group\" style=\"width: 180px;\" data-kid=\"126\">\n          <div class=\"w-16 h-16 rounded-sm glass-vizor flex items-center justify-center mb-8 mx-auto relative z-10 group-hover:border-[var(--primary)] transition-colors\" data-kid=\"127\">\n            <span class=\"font-mono-tech font-bold\" data-kid=\"128\">01</span>\n          </div>\n          <div class=\"text-center\" data-kid=\"129\">\n            <h4 class=\"font-bold uppercase tracking-tighter mb-2\" data-kid=\"130\">Immersion</h4>\n            <p class=\"text-[10px] text-slate-500 uppercase tracking-widest font-black\" data-kid=\"131\">2-3 Solar Days</p>\n          </div>\n        </div>\n        <div class=\"timeline-step group\" style=\"width: 180px;\" data-kid=\"132\">\n          <div class=\"w-16 h-16 rounded-sm glass-vizor flex items-center justify-center mb-8 mx-auto relative z-10 group-hover:border-[var(--primary)] transition-colors\" data-kid=\"133\">\n            <span class=\"font-mono-tech font-bold\" data-kid=\"134\">02</span>\n          </div>\n          <div class=\"text-center\" data-kid=\"135\">\n            <h4 class=\"font-bold uppercase tracking-tighter mb-2\" data-kid=\"136\">Systems</h4>\n            <p class=\"text-[10px] text-slate-500 uppercase tracking-widest font-black\" data-kid=\"137\">7 Solar Days</p>\n          </div>\n        </div>\n        <div class=\"timeline-step group\" style=\"width: 180px;\" data-kid=\"138\">\n          <div class=\"w-16 h-16 rounded-sm glass-vizor flex items-center justify-center mb-8 mx-auto relative z-10 group-hover:border-[var(--primary)] transition-colors\" data-kid=\"139\">\n            <span class=\"font-mono-tech font-bold\" data-kid=\"140\">03</span>\n          </div>\n          <div class=\"text-center\" data-kid=\"141\">\n            <h4 class=\"font-bold uppercase tracking-tighter mb-2\" data-kid=\"142\">Refinement</h4>\n            <p class=\"text-[10px] text-slate-500 uppercase tracking-widest font-black\" data-kid=\"143\">7 Solar Days</p>\n          </div>\n        </div>\n        <div class=\"timeline-step group\" style=\"width: 180px;\" data-kid=\"144\">\n          <div class=\"w-16 h-16 rounded-sm glass-vizor flex items-center justify-center mb-8 mx-auto relative z-10 group-hover:border-[var(--primary)] transition-colors\" data-kid=\"145\">\n            <span class=\"font-mono-tech font-bold\" data-kid=\"146\">04</span>\n          </div>\n          <div class=\"text-center\" data-kid=\"147\">\n            <h4 class=\"font-bold uppercase tracking-tighter mb-2\" data-kid=\"148\">Sim Ops</h4>\n            <p class=\"text-[10px] text-slate-500 uppercase tracking-widest font-black\" data-kid=\"149\">21 Solar Days</p>\n          </div>\n        </div>\n        <div class=\"timeline-step group\" style=\"width: 180px;\" data-kid=\"150\">\n          <div class=\"w-16 h-16 rounded-sm glass-vizor flex items-center justify-center mb-8 mx-auto relative z-10 group-hover:border-[var(--accent)] transition-colors\" data-kid=\"151\">\n            <span class=\"font-mono-tech font-bold text-[var(--accent)]\" data-kid=\"152\">05</span>\n          </div>\n          <div class=\"text-center\" data-kid=\"153\">\n            <h4 class=\"font-bold uppercase tracking-tighter mb-2\" data-kid=\"154\">Career Link</h4>\n            <p class=\"text-[10px] text-slate-500 uppercase tracking-widest font-black\" data-kid=\"155\">Deployment</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-32 bg-black overflow-hidden\" data-kid=\"156\">\n    <div class=\"premium-glow absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full pointer-events-none opacity-40\" data-kid=\"157\"></div>\n    \n    <div class=\"max-w-7xl mx-auto px-12 relative z-10\" data-kid=\"158\">\n      <div class=\"text-center mb-24\" data-kid=\"159\">\n        <span class=\"text-[var(--primary)] font-mono-tech uppercase tracking-[0.3em] text-xs\" data-kid=\"160\">Access Tiers</span>\n        <h2 class=\"text-6xl font-bold mt-4\" data-kid=\"161\">Strategic Investment</h2>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"162\">\n        \n        <div class=\"glass-vizor p-16 rounded-sm flex flex-col items-start h-full hover:bg-white/[0.03] transition-colors\" data-kid=\"163\">\n          <span class=\"text-xs uppercase font-bold tracking-[0.3em] mb-4 text-slate-500\" data-kid=\"164\">Initiate</span>\n          <h3 class=\"text-4xl font-bold mb-8\" data-kid=\"165\">Basic</h3>\n          <div class=\"font-mono-tech text-3xl mb-12\" data-kid=\"166\">FREE</div>\n          <ul class=\"space-y-6 mb-12 flex-grow\" data-kid=\"167\">\n            <li class=\"flex items-center gap-3 text-sm text-slate-400\" data-kid=\"168\"><span class=\"font-mono-tech text-[var(--primary)]\" data-kid=\"169\">[x]</span> 3 Base Modules</li>\n            <li class=\"flex items-center gap-3 text-sm text-slate-400\" data-kid=\"170\"><span class=\"font-mono-tech text-[var(--primary)]\" data-kid=\"171\">[x]</span> Core Documentation</li>\n            <li class=\"flex items-center gap-3 text-sm text-slate-400 opacity-30\" data-kid=\"172\"><span class=\"font-mono-tech\" data-kid=\"173\">[-]</span> AI Simulator</li>\n            <li class=\"flex items-center gap-3 text-sm text-slate-400 opacity-30\" data-kid=\"174\"><span class=\"font-mono-tech\" data-kid=\"175\">[-]</span> Mentor Access</li>\n          </ul>\n          <button class=\"w-full py-4 border border-white/10 uppercase tracking-widest text-xs font-bold hover:bg-white hover:text-black transition-all\" data-kid=\"176\">Start Onboarding</button>\n        </div>\n\n        \n        <div class=\"bg-white text-black p-16 rounded-sm flex flex-col items-start h-full shadow-[0_0_80px_rgba(6,182,212,0.3)] relative scale-105 z-20\" data-kid=\"177\">\n          <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-[var(--accent)] text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-full\" data-kid=\"178\">Recommended</div>\n          <span class=\"text-xs uppercase font-bold tracking-[0.3em] mb-4 text-black/40\" data-kid=\"179\">Full Command</span>\n          <h3 class=\"text-4xl font-bold mb-8\" data-kid=\"180\">Professional</h3>\n          <div class=\"font-mono-tech text-3xl mb-12 text-[var(--primary)]\" data-kid=\"181\">$1,000 <span class=\"text-sm text-black/40 font-sans tracking-normal\" data-kid=\"182\">/ year</span></div>\n          <ul class=\"space-y-6 mb-12 flex-grow\" data-kid=\"183\">\n            <li class=\"flex items-center gap-3 text-sm font-bold\" data-kid=\"184\"><span class=\"font-mono-tech text-[var(--primary)]\" data-kid=\"185\">[x]</span> Full 15 Module Access</li>\n            <li class=\"flex items-center gap-3 text-sm font-bold\" data-kid=\"186\"><span class=\"font-mono-tech text-[var(--primary)]\" data-kid=\"187\">[x]</span> AI Simulation Engine</li>\n            <li class=\"flex items-center gap-3 text-sm font-bold\" data-kid=\"188\"><span class=\"font-mono-tech text-[var(--primary)]\" data-kid=\"189\">[x]</span> 300+ Active Case Studies</li>\n            <li class=\"flex items-center gap-3 text-sm font-bold\" data-kid=\"190\"><span class=\"font-mono-tech text-[var(--primary)]\" data-kid=\"191\">[x]</span> 24/7 Intel Feed Access</li>\n          </ul>\n          <button class=\"w-full py-5 bg-black text-white uppercase tracking-widest text-xs font-black hover:bg-[var(--primary)] transition-all\" data-kid=\"192\">Secure Access</button>\n        </div>\n\n        \n        <div class=\"glass-vizor p-16 rounded-sm flex flex-col items-start h-full hover:bg-white/[0.03] transition-colors border-[var(--accent)]/20\" data-kid=\"193\">\n          <span class=\"text-xs uppercase font-bold tracking-[0.3em] mb-4 text-slate-500\" data-kid=\"194\">Mastery</span>\n          <h3 class=\"text-4xl font-bold mb-8\" data-kid=\"195\">Elite</h3>\n          <div class=\"font-mono-tech text-3xl mb-12 text-[var(--accent)]\" data-kid=\"196\">$1,750</div>\n          <ul class=\"space-y-6 mb-12 flex-grow\" data-kid=\"197\">\n            <li class=\"flex items-center gap-3 text-sm text-slate-400\" data-kid=\"198\"><span class=\"font-mono-tech text-[var(--accent)]\" data-kid=\"199\">[x]</span> Private Strategic Mentor</li>\n            <li class=\"flex items-center gap-3 text-sm text-slate-400\" data-kid=\"200\"><span class=\"font-mono-tech text-[var(--accent)]\" data-kid=\"201\">[x]</span> Priority Job Matching</li>\n            <li class=\"flex items-center gap-3 text-sm text-slate-400\" data-kid=\"202\"><span class=\"font-mono-tech text-[var(--accent)]\" data-kid=\"203\">[x]</span> Closed Elite Community</li>\n            <li class=\"flex items-center gap-3 text-sm text-slate-400\" data-kid=\"204\"><span class=\"font-mono-tech text-[var(--accent)]\" data-kid=\"205\">[x]</span> Weekly VIP Tactical Syncs</li>\n          </ul>\n          <button class=\"w-full py-4 border border-[var(--accent)]/30 text-[var(--accent)] uppercase tracking-widest text-xs font-bold hover:bg-[var(--accent)] hover:text-white transition-all\" data-kid=\"206\">Apply for Elite</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-48 px-12 text-center bg-black overflow-hidden\" data-kid=\"207\">\n    <img src=\"https://images.unsplash.com/photo-1590504805643-bb1f94cde7fd?q=80&w=1440\" class=\"absolute inset-0 w-full h-full object-cover opacity-20 grayscale\" loading=\"lazy\" data-kid=\"208\">\n    <div class=\"absolute inset-0 bg-linear-to-b from-black via-black/80 to-black\" data-kid=\"209\"></div>\n    \n    <div class=\"relative z-10 max-w-4xl mx-auto\" data-kid=\"210\">\n      <span class=\"inline-block mb-8 text-[var(--primary)] font-mono-tech text-lg uppercase tracking-[0.5em] animate-pulse\" data-kid=\"211\">Ready to Deployment</span>\n      <h2 class=\"massive-type text-7xl md:text-9xl mb-12\" data-kid=\"212\">Command Your <br data-kid=\"213\">Future.</h2>\n      <p class=\"text-xl text-slate-400 mb-16 font-light max-w-2xl mx-auto\" data-kid=\"214\">Stop observing the supply chain. Start controlling it. Your operational career begins with a single command.</p>\n      \n      <div class=\"flex flex-col md:flex-row gap-6 justify-center\" data-kid=\"215\">\n        <button class=\"btn-elite rounded-full shadow-[0_0_40px_rgba(255,255,255,0.1)]\" data-kid=\"216\">Initialize Training</button>\n        <button class=\"px-12 py-5 rounded-full border border-white/20 uppercase tracking-widest text-xs font-bold hover:bg-white/5 transition-all\" data-kid=\"217\">Schedule Intel Sync</button>\n      </div>\n\n      <div class=\"mt-24 flex justify-center gap-12 text-slate-600 font-mono-tech text-[10px] uppercase tracking-widest\" data-kid=\"218\">\n        <span data-kid=\"219\">Lifetime Access Granted</span>\n        <span data-kid=\"220\">Secure Protocol 256-Bit</span>\n        <span data-kid=\"221\">24/7 Tactical Support</span>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-12 border-t border-white/5 px-12 text-center bg-black\" data-kid=\"222\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center opacity-40\" data-kid=\"223\">\n        <span class=\"font-mono-tech text-[10px] uppercase tracking-[0.3em]\" data-kid=\"224\">© 2026 DISPATCH4YOU STRATEGIC OPS</span>\n        <div class=\"flex gap-8 mt-4 md:mt-0\" data-kid=\"225\">\n            <a href=\"#\" class=\"text-[10px] uppercase tracking-widest hover:text-white\" data-kid=\"226\">Protocol</a>\n            <a href=\"#\" class=\"text-[10px] uppercase tracking-widest hover:text-white\" data-kid=\"227\">Compliance</a>\n            <a href=\"#\" class=\"text-[10px] uppercase tracking-widest hover:text-white\" data-kid=\"228\">Terms</a>\n        </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js\" data-kid=\"229\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js\" data-kid=\"230\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"231\">\n\n<script data-kid=\"232\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  window.addEventListener('load', () => {\n    // Hero Entrance\n    const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.5 } });\n    \n    tl.from('.reveal-split', {\n      opacity: 0,\n      y: 100,\n      skewY: 7,\n      stagger: 0.1\n    })\n    .from('.reveal-y', {\n      opacity: 0,\n      y: 40,\n      stagger: 0.1\n    }, '-=1');\n\n    // Parallax Videos\n    document.querySelectorAll('.parallax-video').forEach(video => {\n      gsap.to(video, {\n        yPercent: 20,\n        ease: 'none',\n        scrollTrigger: {\n          trigger: video.parentElement,\n          start: 'top bottom',\n          end: 'bottom top',\n          scrub: true\n        }\n      });\n    });\n\n    // Stats Counter\n    document.querySelectorAll('.counter').forEach(counter => {\n      const target = parseFloat(counter.getAttribute('data-target'));\n      const prefix = counter.getAttribute('data-prefix') || '';\n      const suffix = counter.getAttribute('data-suffix') || '';\n      const decimals = parseInt(counter.getAttribute('data-decimal') || '0');\n      \n      const obj = { val: 0 };\n      gsap.to(obj, {\n        val: target,\n        scrollTrigger: {\n          trigger: counter,\n          start: 'top 85%'\n        },\n        duration: 2,\n        onUpdate: () => {\n          counter.innerText = prefix + obj.val.toFixed(decimals) + suffix;\n        }\n      });\n    });\n\n    // Timeline Path Progress\n    gsap.to('#timeline-scroll-progress', {\n      width: '100%',\n      ease: 'none',\n      scrollTrigger: {\n        trigger: '.timeline-step',\n        start: 'top center',\n        end: 'bottom center',\n        scrub: true\n      }\n    });\n\n    // Smooth reveal for all sections\n    gsap.utils.toArray('section').forEach(section => {\n      gsap.from(section, {\n        opacity: 0,\n        y: 50,\n        duration: 1,\n        scrollTrigger: {\n          trigger: section,\n          start: 'top 80%',\n          toggleActions: 'play none none reverse'\n        }\n      });\n    });\n  });\n</script>",
