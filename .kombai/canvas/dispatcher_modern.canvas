ion-all\" data-kid=\"195\">ENROLL_PREMIUM</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 relative\" data-kid=\"196\">\n    <div class=\"absolute inset-0 z-0\" data-kid=\"197\">\n      <img src=\"https://images.unsplash.com/photo-1590504805643-bb1f94cde7fd?q=80&w=1440\" class=\"w-full h-full object-cover opacity-20 grayscale scale-110\" id=\"cta-bg\" alt=\"Fleet\" data-kid=\"198\">\n      <div class=\"absolute inset-0 bg-gradient-to-t from-bg-deep via-bg-deep/80 to-transparent\" data-kid=\"199\"></div>\n    </div>\n    \n    <div class=\"container mx-auto px-10 relative z-10 text-center\" data-kid=\"200\">\n      <div class=\"reveal max-w-4xl mx-auto\" data-kid=\"201\">\n        <span class=\"mono-data text-cyan-400 text-xs mb-6 block tracking-[0.3em]\" data-kid=\"202\">FINAL_COMMAND_PROMPT</span>\n        <h2 class=\"massive-type text-8xl text-white mb-10\" data-kid=\"203\">READY TO INITIALIZE?</h2>\n        <p class=\"text-2xl text-slate-400 font-light mb-16 max-w-2xl mx-auto leading-relaxed\" data-kid=\"204\">\n          The future of logistics dispatching starts here. Join 500+ active operators dominating the US market.\n        </p>\n        \n        <div class=\"grid grid-cols-3 gap-10 mb-16 border-y border-white/5 py-12\" data-kid=\"205\">\n          <div data-kid=\"206\">\n            <div class=\"text-4xl font-bold massive-type text-white\" data-kid=\"207\">500+</div>\n            <div class=\"mono-data text-[10px] text-white/30\" data-kid=\"208\">OPERATORS</div>\n          </div>\n          <div data-kid=\"209\">\n            <div class=\"text-4xl font-bold massive-type text-white\" data-kid=\"210\">$3.5K</div>\n            <div class=\"mono-data text-[10px] text-white/30\" data-kid=\"211\">AVG_START_SALARY</div>\n          </div>\n          <div data-kid=\"212\">\n            <div class=\"text-4xl font-bold massive-type text-white\" data-kid=\"213\">4.8/5</div>\n            <div class=\"mono-data text-[10px] text-white/30\" data-kid=\"214\">SYSTEM_RATING</div>\n          </div>\n        </div>\n\n        <a href=\"#pricing\" class=\"inline-block px-16 py-6 bg-white text-black font-black uppercase tracking-[0.2em] text-sm hover:bg-cyan-400 transition-all shadow-[0_0_40px_rgba(255,255,255,0.2)]\" data-kid=\"215\">\n          EXECUTE_ENROLLMENT.exe\n        </a>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-10 border-t border-white/5 opacity-30\" data-kid=\"216\">\n    <div class=\"container mx-auto px-10 flex justify-between mono-data text-[9px]\" data-kid=\"217\">\n      <div data-kid=\"218\">DISPATCH4YOU_ACADEMY // COPYRIGHT_2026</div>\n      <div data-kid=\"219\">TERMINAL_ID: 104-582-993</div>\n    </div>\n  </footer>\n</main>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"220\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"221\"></script>\n\n<script data-kid=\"222\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  window.addEventListener('load', () => {\n    // Initial Reveal Timeline\n    const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.2 } });\n    \n    tl.to('.reveal', {\n      opacity: 1,\n      y: 0,\n      stagger: 0.1\n    });\n\n    // Marquee\n    gsap.to('.animate-marquee', {\n      xPercent: -50,\n      repeat: -1,\n      duration: 20,\n      ease: 'none'\n    });\n\n    // Scroll Reveal for each section\n    document.querySelectorAll('.reveal').forEach(el => {\n      gsap.to(el, {\n        opacity: 1,\n        y: 0,\n        scrollTrigger: {\n          trigger: el,\n          start: 'top 90%',\n        }\n      });\n    });\n\n    // Wire Fill Animation\n    gsap.to('#wire-fill', {\n      height: '100%',\n      ease: 'none',\n      scrollTrigger: {\n        trigger: '#how-it-works',\n        start: 'top center',\n        end: 'bottom center',\n        scrub: true\n      }\n    });\n\n    // Parallax CTA BG\n    gsap.to('#cta-bg', {\n      yPercent: -20,\n      scale: 1,\n      scrollTrigger: {\n        trigger: '#cta-bg',\n        scrub: true\n      }\n    });\n  });\n</script>",
