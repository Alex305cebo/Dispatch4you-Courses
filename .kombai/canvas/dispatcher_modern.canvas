      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-darker: #070b14;\n    --bg-dark: #0a0e1a;\n    --primary: #06b6d4;\n    --secondary: #0ea5e9;\n    --accent: #f97316;\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-darker);\n    color: white;\n    overflow-x: hidden;\n  }\n\n  .font-heading { font-family: 'Montserrat', sans-serif; }\n\n  .glass-card {\n    background: var(--glass-bg);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  .glass-card:hover {\n    border-color: rgba(6, 182, 212, 0.4);\n    background: rgba(255, 255, 255, 0.05);\n  }\n\n  .gradient-text {\n    background: linear-gradient(135deg, #06b6d4, #0ea5e9, #f97316);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  .btn-primary {\n    background: linear-gradient(135deg, var(--primary), var(--secondary));\n    transition: all 0.3s ease;\n  }\n\n  .btn-primary:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 0 20px rgba(6, 182, 212, 0.4);\n  }\n\n  /* Custom scrollbar */\n  ::-webkit-scrollbar { width: 8px; }\n  ::-webkit-scrollbar-track { background: var(--bg-darker); }\n  ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: #334155; }\n\n  .reveal { opacity: 0; transform: translateY(30px); }\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"1\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"2\"></script>\n\n<div class=\"relative\" data-kid=\"3\">\n  \n  <section class=\"relative h-screen flex items-center overflow-hidden\" data-kid=\"4\">\n    \n    <video src=\"https://videos.pexels.com/video-files/30507710/13070387_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/30507710/auto-automotives-cars-freeway-30507710.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute top-0 left-0 w-full h-full object-cover z-0\" data-kid=\"5\"></video>\n    <div class=\"absolute top-0 left-0 w-full h-full bg-linear-to-b from-black/60 via-black/40 to-[#070b14] z-10\" data-kid=\"6\"></div>\n\n    <div class=\"container mx-auto px-6 relative z-20\" data-kid=\"7\">\n      <div class=\"max-w-3xl\" data-kid=\"8\">\n        <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass-card border-cyan-500/30 mb-8 animate-pulse\" data-kid=\"9\">\n          <span class=\"w-2 h-2 rounded-full bg-cyan-500\" data-kid=\"10\"></span>\n          <span class=\"text-xs font-bold uppercase tracking-widest text-cyan-400\" data-kid=\"11\">Набор открыт</span>\n        </div>\n        \n        <h1 class=\"text-6xl md:text-8xl font-heading font-black leading-none mb-6\" data-kid=\"12\">\n          Станьте <span class=\"gradient-text\" data-kid=\"13\">Диспетчером</span><br data-kid=\"14\">\n          грузоперевозок США\n        </h1>\n        \n        <p class=\"text-xl text-white/80 leading-relaxed mb-10 max-w-2xl\" data-kid=\"15\">\n          Удалённая профессия в сфере логистики. Обучение с нуля, практика на реальных кейсах и поддержка до первой работы. Зарабатывайте от $3,000/мес из любой точки мира.\n        </p>\n\n        <div class=\"flex flex-wrap items-center gap-6\" data-kid=\"16\">\n          <a href=\"#how-it-works\" class=\"btn-primary px-8 py-4 rounded-xl font-bold text-lg flex items-center gap-2\" data-kid=\"17\">\n            Смотреть программу \n            <i class=\"ti ti-arrow-right\" data-kid=\"18\"></i>\n          </a>\n          \n          <div class=\"flex items-center gap-4 glass-card px-6 py-3 rounded-xl border-white/10\" data-kid=\"19\">\n            <div class=\"flex -space-x-2\" data-kid=\"20\">\n              <img src=\"https://i.pravatar.cc/40?u=1\" class=\"w-8 h-8 rounded-full border-2 border-slate-900\" decoding=\"async\" loading=\"lazy\" data-kid=\"21\">\n              <img src=\"https://i.pravatar.cc/40?u=2\" class=\"w-8 h-8 rounded-full border-2 border-slate-900\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n              <img src=\"https://i.pravatar.cc/40?u=3\" class=\"w-8 h-8 rounded-full border-2 border-slate-900\" decoding=\"async\" loading=\"lazy\" data-kid=\"23\">\n            </div>\n            <div data-kid=\"24\">\n              <div class=\"flex items-center gap-1 text-orange-500 text-sm\" data-kid=\"25\">\n                <i class=\"ti ti-star-filled\" data-kid=\"26\"></i>\n                <i class=\"ti ti-star-filled\" data-kid=\"27\"></i>\n                <i class=\"ti ti-star-filled\" data-kid=\"28\"></i>\n                <i class=\"ti ti-star-filled\" data-kid=\"29\"></i>\n                <i class=\"ti ti-star-half-filled\" data-kid=\"30\"></i>\n                <span class=\"text-white font-bold ml-1\" data-kid=\"31\">4.8</span>\n              </div>\n              <p class=\"text-[10px] uppercase tracking-wider text-white/50\" data-kid=\"32\">500+ студентов</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 text-white/30\" data-kid=\"33\">\n      <span class=\"text-[10px] uppercase tracking-[0.3em] font-bold\" data-kid=\"34\">Листайте вниз</span>\n      <div class=\"w-px h-12 bg-linear-to-b from-cyan-500/50 to-transparent\" data-kid=\"35\"></div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 relative overflow-hidden\" data-kid=\"36\">\n    <div class=\"absolute inset-0 z-0 opacity-10\" data-kid=\"37\">\n      <img src=\"https://images.pexels.com/photos/5833758/pexels-photo-5833758.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80\" class=\"w-full h-full object-cover grayscale\" decoding=\"async\" loading=\"lazy\" data-kid=\"38\">\n    </div>\n    <div class=\"absolute inset-0 bg-linear-to-b from-[#070b14] via-[#070b14]/90 to-[#070b14] z-0\" data-kid=\"39\"></div>\n\n    <div class=\"container mx-auto px-6 relative z-10\" data-kid=\"40\">\n      <div class=\"text-center mb-20 reveal\" data-kid=\"41\">\n        <span class=\"text-cyan-500 font-bold uppercase tracking-widest text-sm mb-4 block\" data-kid=\"42\">⭐ Почему выбирают нас</span>\n        <h2 class=\"text-4xl md:text-5xl font-heading font-extrabold mb-6\" data-kid=\"43\">\n          Закрытое <span class=\"text-cyan-400\" data-kid=\"44\">Комьюнити</span> профессионалов\n        </h2>\n        <p class=\"text-white/60 max-w-2xl mx-auto\" data-kid=\"45\">Эксклюзивная платформа для подготовки диспетчеров высшего уровня.</p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\" data-kid=\"46\">\n        \n        <div class=\"glass-card p-10 rounded-3xl reveal border-t-cyan-500/20 group\" data-kid=\"47\">\n          <div class=\"w-14 h-14 rounded-2xl bg-cyan-500/10 flex items-center justify-center mb-8 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"48\">\n            <i class=\"ti ti-cpu text-3xl text-cyan-400\" data-kid=\"49\"></i>\n          </div>\n          <h3 class=\"text-2xl font-bold mb-4 font-heading tracking-tight\" data-kid=\"50\">Реальная практика</h3>\n          <p class=\"text-white/60 leading-relaxed mb-6\" data-kid=\"51\">Тренируйся вести переговоры с брокерами в нашем AI-симуляторе. 50+ сценариев реальных звонков.</p>\n          <div class=\"pt-6 border-t border-white/5 flex items-center justify-between\" data-kid=\"52\">\n            <span class=\"text-xs font-bold uppercase tracking-wider text-cyan-500\" data-kid=\"53\">AI Practice</span>\n            <span class=\"text-sm text-white/40\" data-kid=\"54\">+120 студентов</span>\n          </div>\n        </div>\n\n        \n        <div class=\"glass-card p-10 rounded-3xl reveal border-t-purple-500/20 group translate-y-12\" data-kid=\"55\">\n          <div class=\"w-14 h-14 rounded-2xl bg-purple-500/10 flex items-center justify-center mb-8 group-hover:bg-purple-500/20 transition-colors\" data-kid=\"56\">\n            <i class=\"ti ti-headset text-3xl text-purple-400\" data-kid=\"57\"></i>\n          </div>\n          <h3 class=\"text-2xl font-bold mb-4 font-heading tracking-tight\" data-kid=\"58\">24/7 Поддержка</h3>\n          <p class=\"text-white/60 leading-relaxed mb-6\" data-kid=\"59\">Действующие диспетчеры отвечают на вопросы в закрытом чате. Разбор ошибок каждую неделю.</p>\n          <div class=\"pt-6 border-t border-white/5 flex items-center justify-between\" data-kid=\"60\">\n            <span class=\"text-xs font-bold uppercase tracking-wider text-purple-500\" data-kid=\"61\">Mentor Support</span>\n            <span class=\"text-sm text-white/40\" data-kid=\"62\">~15 мин ответ</span>\n          </div>\n        </div>\n\n        \n        <div class=\"glass-card p-10 rounded-3xl reveal border-t-orange-500/20 group\" data-kid=\"63\">\n          <div class=\"w-14 h-14 rounded-2xl bg-orange-500/10 flex items-center justify-center mb-8 group-hover:bg-orange-500/20 transition-colors\" data-kid=\"64\">\n            <i class=\"ti ti-trending-up text-3xl text-orange-400\" data-kid=\"65\"></i>\n          </div>\n          <h3 class=\"text-2xl font-bold mb-4 font-heading tracking-tight\" data-kid=\"66\">Карьерный рост</h3>\n          <p class=\"text-white/60 leading-relaxed mb-6\" data-kid=\"67\">Помощь с резюме, подготовка к собеседованию и доступ к эксклюзивной базе вакансий.</p>\n          <div class=\"pt-6 border-t border-white/5 flex items-center justify-between\" data-kid=\"68\">\n            <span class=\"text-xs font-bold uppercase tracking-wider text-orange-500\" data-kid=\"69\">Career Focus</span>\n            <span class=\"text-sm text-white/40\" data-kid=\"70\">87% успех</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-linear-to-b from-[#070b14] to-[#0a0e1a]\" data-kid=\"71\">\n    <div class=\"container mx-auto px-6\" data-kid=\"72\">\n      <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-16 reveal\" data-kid=\"73\">\n        <div class=\"max-w-2xl\" data-kid=\"74\">\n          <h2 class=\"text-4xl md:text-5xl font-heading font-extrabold mb-4\" data-kid=\"75\">Что вы <span class=\"gradient-text\" data-kid=\"76\">Получите</span></h2>\n          <p class=\"text-white/60\" data-kid=\"77\">Актуальные знания о рынке грузоперевозок США и все необходимые инструменты для работы.</p>\n        </div>\n        <div class=\"flex gap-4 mt-8 md:mt-0\" data-kid=\"78\">\n          <button class=\"w-12 h-12 rounded-full glass-card flex items-center justify-center hover:bg-white/10 transition-colors\" id=\"prev-feat\" data-kid=\"79\">\n            <i class=\"ti ti-chevron-left\" data-kid=\"80\"></i>\n          </button>\n          <button class=\"w-12 h-12 rounded-full glass-card flex items-center justify-center hover:bg-white/10 transition-colors\" id=\"next-feat\" data-kid=\"81\">\n            <i class=\"ti ti-chevron-right\" data-kid=\"82\"></i>\n          </button>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 overflow-hidden\" id=\"feature-grid\" data-kid=\"83\">\n        \n        <div class=\"glass-card p-8 rounded-2xl reveal group cursor-pointer hover:border-cyan-500/40 transition-all\" data-kid=\"84\">\n          <div class=\"text-4xl mb-6\" data-kid=\"85\">📖</div>\n          <h4 class=\"text-xl font-bold mb-2 font-heading\" data-kid=\"86\">Документация</h4>\n          <p class=\"text-white/50 text-sm leading-relaxed\" data-kid=\"87\">Полная база знаний диспетчера с шаблонами Rate Con, BOL, POD и чек-листами.</p>\n        </div>\n        \n        <div class=\"glass-card p-8 rounded-2xl reveal group cursor-pointer hover:border-cyan-500/40 transition-all\" data-kid=\"88\">\n          <div class=\"text-4xl mb-6\" data-kid=\"89\">📞</div>\n          <h4 class=\"text-xl font-bold mb-2 font-heading\" data-kid=\"90\">Dispatch Simulator</h4>\n          <p class=\"text-white/50 text-sm leading-relaxed\" data-kid=\"91\">AI-симулятор для отработки холодных звонков и переговоров с американскими брокерами.</p>\n        </div>\n        \n        <div class=\"glass-card p-8 rounded-2xl reveal group cursor-pointer hover:border-cyan-500/40 transition-all\" data-kid=\"92\">\n          <div class=\"text-4xl mb-6\" data-kid=\"93\">🎯</div>\n          <h4 class=\"text-xl font-bold mb-2 font-heading\" data-kid=\"94\">Тренажёр Диспетчера</h4>\n          <p class=\"text-white/50 text-sm leading-relaxed\" data-kid=\"95\">Интерактивные флеш-карточки и квизы по географии штатов и типам оборудования.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative h-[600px] flex items-center overflow-hidden\" data-kid=\"96\">\n    <video src=\"https://videos.pexels.com/video-files/34342557/14549187_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/34342557/pexels-photo-34342557.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute top-0 left-0 w-full h-full object-cover z-0 scale-110\" id=\"map-video\" data-kid=\"97\"></video>\n    <div class=\"absolute inset-0 bg-black/60 z-10\" data-kid=\"98\"></div>\n    \n    <div class=\"container mx-auto px-6 relative z-20 text-center reveal\" data-kid=\"99\">\n      <div class=\"inline-block px-6 py-2 rounded-full glass-card border-cyan-500/40 mb-8\" data-kid=\"100\">\n        <span class=\"text-xs font-bold uppercase tracking-widest text-cyan-400\" data-kid=\"101\">Advanced Tooling</span>\n      </div>\n      <h2 class=\"text-5xl md:text-7xl font-heading font-black mb-8 leading-tight\" data-kid=\"102\">USA MAP TRAINER</h2>\n      <p class=\"text-xl text-white/80 max-w-3xl mx-auto mb-12\" data-kid=\"103\">\n        Освойте географию США и логистические хабы с помощью нашего уникального интерактивного тренажера. Знание штатов — это +20% к вашей эффективности.\n      </p>\n      <a href=\"map-trainer/\" class=\"inline-flex items-center gap-3 glass-card px-10 py-5 rounded-2xl font-bold text-xl hover:bg-cyan-500/20 transition-all\" data-kid=\"104\">\n        Запустить тренажер\n        <i class=\"ti ti-external-link\" data-kid=\"105\"></i>\n      </a>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-[#070b14]\" data-kid=\"106\">\n    <div class=\"container mx-auto px-6\" data-kid=\"107\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16\" data-kid=\"108\">\n        <div class=\"lg:col-span-5 sticky top-32 h-fit reveal\" data-kid=\"109\">\n          <span class=\"text-orange-500 font-bold uppercase tracking-widest text-sm mb-4 block\" data-kid=\"110\">💼 Профессия Будущего</span>\n          <h2 class=\"text-4xl md:text-5xl font-heading font-extrabold mb-8 leading-tight\" data-kid=\"111\">\n            Почему стоит стать <span class=\"text-orange-400\" data-kid=\"112\">Диспетчером</span> сейчас\n          </h2>\n          <div class=\"space-y-8 mt-12\" data-kid=\"113\">\n            <div class=\"flex items-center gap-6\" data-kid=\"114\">\n              <div class=\"text-5xl font-black font-heading text-cyan-500/20\" data-kid=\"115\">$875B</div>\n              <p class=\"text-sm text-white/50 uppercase tracking-widest font-bold\" data-kid=\"116\">Объем рынка США в год</p>\n            </div>\n            <div class=\"flex items-center gap-6\" data-kid=\"117\">\n              <div class=\"text-5xl font-black font-heading text-purple-500/20\" data-kid=\"118\">3.5M+</div>\n              <p class=\"text-sm text-white/50 uppercase tracking-widest font-bold\" data-kid=\"119\">Грузовиков на дорогах</p>\n            </div>\n            <div class=\"flex items-center gap-6\" data-kid=\"120\">\n              <div class=\"text-5xl font-black font-heading text-orange-500/20\" data-kid=\"121\">70%</div>\n              <p class=\"text-sm text-white/50 uppercase tracking-widest font-bold\" data-kid=\"122\">Всех грузов США возят траки</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"lg:col-span-7 space-y-8\" data-kid=\"123\">\n          \n          <div class=\"glass-card p-10 rounded-3xl reveal hover:translate-x-4 transition-transform group\" data-kid=\"124\">\n            <div class=\"flex items-start gap-8\" data-kid=\"125\">\n              <div class=\"w-16 h-16 rounded-2xl bg-cyan-500/10 flex items-center justify-center shrink-0\" data-kid=\"126\">\n                <span class=\"text-3xl text-cyan-400\" data-kid=\"127\">💰</span>\n              </div>\n              <div data-kid=\"128\">\n                <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"129\">Высокий доход</h3>\n                <p class=\"text-white/60 leading-relaxed\" data-kid=\"130\">Диспетчеры зарабатывают процент от каждого груза. При работе с 5-7 траками ваш доход может превышать $10,000 в месяц. Выплаты еженедельно.</p>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"glass-card p-10 rounded-3xl reveal hover:translate-x-4 transition-transform group\" data-kid=\"131\">\n            <div class=\"flex items-start gap-8\" data-kid=\"132\">\n              <div class=\"w-16 h-16 rounded-2xl bg-purple-500/10 flex items-center justify-center shrink-0\" data-kid=\"133\">\n                <span class=\"text-3xl text-purple-400\" data-kid=\"134\">🌍</span>\n              </div>\n              <div data-kid=\"135\">\n                <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"136\">Полная удаленка</h3>\n                <p class=\"text-white/60 leading-relaxed\" data-kid=\"137\">Для работы нужен только ноутбук, быстрый интернет и хороший уровень английского. Работайте из Бали, Тбилиси или Варшавы — вы не привязаны к офису.</p>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"glass-card p-10 rounded-3xl reveal hover:translate-x-4 transition-transform group\" data-kid=\"138\">\n            <div class=\"flex items-start gap-8\" data-kid=\"139\">\n              <div class=\"w-16 h-16 rounded-2xl bg-orange-500/10 flex items-center justify-center shrink-0\" data-kid=\"140\">\n                <span class=\"text-3xl text-orange-400\" data-kid=\"141\">⏰</span>\n              </div>\n              <div data-kid=\"142\">\n                <h3 class=\"text-2xl font-bold mb-4 font-heading\" data-kid=\"143\">Гибкий график</h3>\n                <p class=\"text-white/60 leading-relaxed\" data-kid=\"144\">Вы сами формируете свой рабочий день. Большинство брокеров в США работают в дневное время (разница во времени позволяет удобно совмещать с личной жизнью).</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"how-it-works\" class=\"py-32 relative bg-linear-to-b from-[#0a0e1a] to-[#070b14]\" data-kid=\"145\">\n    <div class=\"container mx-auto px-6\" data-kid=\"146\">\n      <div class=\"text-center mb-24 reveal\" data-kid=\"147\">\n        <h2 class=\"text-4xl md:text-5xl font-heading font-extrabold mb-4\" data-kid=\"148\">Как это <span class=\"gradient-text\" data-kid=\"149\">Работает</span></h2>\n        <p class=\"text-white/60\" data-kid=\"150\">Ваш путь в профессию за 5 четких шагов</p>\n      </div>\n\n      <div class=\"relative max-w-5xl mx-auto\" data-kid=\"151\">\n        \n        <div class=\"absolute left-1/2 top-0 bottom-0 w-px bg-linear-to-b from-cyan-500/0 via-cyan-500/50 to-cyan-500/0 hidden md:block\" data-kid=\"152\"></div>\n\n        <div class=\"space-y-24\" data-kid=\"153\">\n          \n          <div class=\"relative flex flex-col md:flex-row items-center gap-12 reveal\" data-kid=\"154\">\n            <div class=\"md:w-1/2 md:text-right\" data-kid=\"155\">\n              <span class=\"text-cyan-500 font-bold text-sm uppercase tracking-widest mb-2 block\" data-kid=\"156\">Шаг 01</span>\n              <h3 class=\"text-3xl font-bold mb-4 font-heading\" data-kid=\"157\">Погружение</h3>\n              <p class=\"text-white/50\" data-kid=\"158\">Знакомство с рынком США, терминологией и ролью диспетчера. Изучаем типы траков и документацию DOT/FMCSA.</p>\n            </div>\n            <div class=\"w-12 h-12 rounded-full glass-card flex items-center justify-center z-10 relative bg-cyan-500 shadow-[0_0_20px_rgba(6,182,212,0.5)]\" data-kid=\"159\">\n              <span class=\"font-black text-white\" data-kid=\"160\">1</span>\n            </div>\n            <div class=\"md:w-1/2\" data-kid=\"161\"></div>\n          </div>\n\n          \n          <div class=\"relative flex flex-col md:flex-row-reverse items-center gap-12 reveal\" data-kid=\"162\">\n            <div class=\"md:w-1/2\" data-kid=\"163\">\n              <span class=\"text-purple-500 font-bold text-sm uppercase tracking-widest mb-2 block\" data-kid=\"164\">Шаг 02</span>\n              <h3 class=\"text-3xl font-bold mb-4 font-heading\" data-kid=\"165\">Инструменты</h3>\n              <p class=\"text-white/50\" data-kid=\"166\">Осваиваем Load Boards (DAT, Truckstop), учимся искать грузы, читать ставки и проверять брокеров.</p>\n            </div>\n            <div class=\"w-12 h-12 rounded-full glass-card flex items-center justify-center z-10 relative bg-purple-500 shadow-[0_0_20px_rgba(168,85,247,0.5)]\" data-kid=\"167\">\n              <span class=\"font-black text-white\" data-kid=\"168\">2</span>\n            </div>\n            <div class=\"md:w-1/2\" data-kid=\"169\"></div>\n          </div>\n\n          \n          <div class=\"relative flex flex-col md:flex-row items-center gap-12 reveal\" data-kid=\"170\">\n            <div class=\"md:w-1/2 md:text-right\" data-kid=\"171\">\n              <span class=\"text-orange-500 font-bold text-sm uppercase tracking-widest mb-2 block\" data-kid=\"172\">Шаг 03</span>\n              <h3 class=\"text-3xl font-bold mb-4 font-heading\" data-kid=\"173\">AI Практика</h3>\n              <p class=\"text-white/50\" data-kid=\"174\">Интенсивные тренировки переговоров в симуляторе. Учимся закрывать выгодные рейсы и решать проблемы.</p>\n            </div>\n            <div class=\"w-12 h-12 rounded-full glass-card flex items-center justify-center z-10 relative bg-orange-500 shadow-[0_0_20px_rgba(249,115,22,0.5)]\" data-kid=\"175\">\n              <span class=\"font-black text-white\" data-kid=\"176\">3</span>\n            </div>\n            <div class=\"md:w-1/2\" data-kid=\"177\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"pricing\" class=\"py-32\" data-kid=\"178\">\n    <div class=\"container mx-auto px-6\" data-kid=\"179\">\n      <div class=\"text-center mb-20 reveal\" data-kid=\"180\">\n        <h2 class=\"text-4xl md:text-5xl font-heading font-extrabold mb-4\" data-kid=\"181\">Выберите свой <span class=\"gradient-text\" data-kid=\"182\">Тариф</span></h2>\n        <p class=\"text-white/60\" data-kid=\"183\">Инвестируйте в свое будущее сегодня</p>\n      </div>\n\n      <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch\" data-kid=\"184\">\n        \n        <div class=\"glass-card p-12 rounded-[40px] flex flex-col reveal border-white/5\" data-kid=\"185\">\n          <div class=\"mb-10\" data-kid=\"186\">\n            <span class=\"text-white/40 uppercase tracking-widest text-xs font-bold mb-4 block\" data-kid=\"187\">Для старта</span>\n            <h3 class=\"text-3xl font-bold mb-4 font-heading\" data-kid=\"188\">Базовый</h3>\n            <div class=\"text-5xl font-black font-heading mb-2\" data-kid=\"189\">FREE</div>\n            <p class=\"text-white/40 text-sm\" data-kid=\"190\">Попробуйте свои силы</p>\n          </div>\n          <ul class=\"space-y-5 mb-12 flex-grow\" data-kid=\"191\">\n            <li class=\"flex items-center gap-3 text-white/80\" data-kid=\"192\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"193\"></i> Доступ к 3 модулям</li>\n            <li class=\"flex items-center gap-3 text-white/80\" data-kid=\"194\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"195\"></i> Глоссарий терминов</li>\n            <li class=\"flex items-center gap-3 text-white/40\" data-kid=\"196\"><i class=\"ti ti-circle-x\" data-kid=\"197\"></i> AI-симулятор переговоров</li>\n            <li class=\"flex items-center gap-3 text-white/40\" data-kid=\"198\"><i class=\"ti ti-circle-x\" data-kid=\"199\"></i> Менторская поддержка</li>\n          </ul>\n          <a href=\"#\" class=\"w-full py-4 rounded-2xl glass-card text-center font-bold hover:bg-white/5 transition-colors\" data-kid=\"200\">Начать бесплатно</a>\n        </div>\n\n        \n        <div class=\"glass-card p-12 rounded-[40px] flex flex-col reveal relative border-cyan-500/50 lg:-translate-y-6 bg-cyan-950/20 scale-105\" data-kid=\"201\">\n          <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 bg-cyan-500 text-black font-black px-6 py-1 rounded-full text-xs uppercase tracking-widest\" data-kid=\"202\">\n            Популярный выбор\n          </div>\n          <div class=\"mb-10\" data-kid=\"203\">\n            <span class=\"text-cyan-400 uppercase tracking-widest text-xs font-bold mb-4 block\" data-kid=\"204\">Полное погружение</span>\n            <h3 class=\"text-3xl font-bold mb-4 font-heading\" data-kid=\"205\">Профессионал</h3>\n            <div class=\"text-5xl font-black font-heading mb-2\" data-kid=\"206\">$800</div>\n            <p class=\"text-white/40 text-sm\" data-kid=\"207\">Оплата один раз. Доступ навсегда.</p>\n          </div>\n          <ul class=\"space-y-5 mb-12 flex-grow\" data-kid=\"208\">\n            <li class=\"flex items-center gap-3 text-white\" data-kid=\"209\"><i class=\"ti ti-circle-check-filled text-cyan-500\" data-kid=\"210\"></i> Все 15 модулей обучения</li>\n            <li class=\"flex items-center gap-3 text-white\" data-kid=\"211\"><i class=\"ti ti-circle-check-filled text-cyan-500\" data-kid=\"212\"></i> Безлимитный AI-симулятор</li>\n            <li class=\"flex items-center gap-3 text-white\" data-kid=\"213\"><i class=\"ti ti-circle-check-filled text-cyan-500\" data-kid=\"214\"></i> 300+ реальных кейсов</li>\n            <li class=\"flex items-center gap-3 text-white\" data-kid=\"215\"><i class=\"ti ti-circle-check-filled text-cyan-500\" data-kid=\"216\"></i> Групповые разборы (live)</li>\n          </ul>\n          <a href=\"#\" class=\"btn-primary w-full py-5 rounded-2xl text-center font-bold text-lg\" data-kid=\"217\">Выбрать этот тариф</a>\n        </div>\n\n        \n        <div class=\"glass-card p-12 rounded-[40px] flex flex-col reveal border-white/5\" data-kid=\"218\">\n          <div class=\"mb-10\" data-kid=\"219\">\n            <span class=\"text-white/40 uppercase tracking-widest text-xs font-bold mb-4 block\" data-kid=\"220\">Максимальный результат</span>\n            <h3 class=\"text-3xl font-bold mb-4 font-heading\" data-kid=\"221\">Премиум</h3>\n            <div class=\"text-5xl font-black font-heading mb-2\" data-kid=\"222\">$1,500</div>\n            <p class=\"text-white/40 text-sm\" data-kid=\"223\">Персональное наставничество</p>\n          </div>\n          <ul class=\"space-y-5 mb-12 flex-grow\" data-kid=\"224\">\n            <li class=\"flex items-center gap-3 text-white/80\" data-kid=\"225\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"226\"></i> Всё из тарифа ПРО</li>\n            <li class=\"flex items-center gap-3 text-white/80\" data-kid=\"227\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"228\"></i> Личный ментор 24/7</li>\n            <li class=\"flex items-center gap-3 text-white/80\" data-kid=\"229\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"230\"></i> Помощь в трудоустройстве</li>\n            <li class=\"flex items-center gap-3 text-white/80\" data-kid=\"231\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"232\"></i> Закрытое VIP комьюнити</li>\n          </ul>\n          <a href=\"#\" class=\"w-full py-4 rounded-2xl glass-card text-center font-bold hover:bg-white/5 transition-colors\" data-kid=\"233\">Стать премиум</a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 relative overflow-hidden\" data-kid=\"234\">\n    <div class=\"absolute inset-0 z-0\" data-kid=\"235\">\n      <img src=\"https://images.unsplash.com/photo-1591419478162-a4dd21b7ec0a?q=80&w=1440&auto=format&fit=crop\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"236\">\n      <div class=\"absolute inset-0 bg-linear-to-r from-[#070b14] via-[#070b14]/80 to-transparent z-10\" data-kid=\"237\"></div>\n    </div>\n\n    <div class=\"container mx-auto px-6 relative z-20\" data-kid=\"238\">\n      <div class=\"max-w-3xl reveal\" data-kid=\"239\">\n        <div class=\"text-cyan-500 font-bold text-sm uppercase tracking-[0.4em] mb-6 flex items-center gap-4\" data-kid=\"240\">\n          <span class=\"w-12 h-px bg-cyan-500\" data-kid=\"241\"></span>\n          Ready to launch?\n        </div>\n        <h2 class=\"text-5xl md:text-7xl font-heading font-black mb-10 leading-tight\" data-kid=\"242\">\n          Готовы начать карьеру <span class=\"gradient-text\" data-kid=\"243\">Диспетчера</span>?\n        </h2>\n        <p class=\"text-xl text-white/70 mb-12 max-w-2xl leading-relaxed\" data-kid=\"244\">\n          Присоединяйтесь к 500+ успешных выпускников. Получите профессию, которая дает свободу передвижения и стабильный доход в долларах.\n        </p>\n        \n        <div class=\"flex flex-wrap gap-6\" data-kid=\"245\">\n          <a href=\"#\" class=\"btn-primary px-12 py-5 rounded-2xl font-bold text-xl\" data-kid=\"246\">Начать сегодня</a>\n          <div class=\"flex items-center gap-4 text-white/50 text-sm\" data-kid=\"247\">\n            <i class=\"ti ti-shield-check text-2xl text-cyan-500\" data-kid=\"248\"></i>\n            <span data-kid=\"249\">Доступ навсегда · 24/7 Поддержка · Гарантия знаний</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-20 border-t border-white/5 bg-[#050810]\" data-kid=\"250\">\n    <div class=\"container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-10\" data-kid=\"251\">\n      <div class=\"flex items-center gap-3\" data-kid=\"252\">\n        <img src=\"logo.svg\" class=\"h-8 opacity-80\" alt=\"Logo\" decoding=\"async\" loading=\"lazy\" data-kid=\"253\">\n        <span class=\"font-heading font-bold text-xl tracking-tighter\" data-kid=\"254\">DISPATCH4YOU</span>\n      </div>\n      <div class=\"flex gap-10 text-sm text-white/40\" data-kid=\"255\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"256\">Политика конфиденциальности</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"257\">Условия использования</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"258\">Связаться с нами</a>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"259\">\n        <a href=\"#\" class=\"w-10 h-10 rounded-xl glass-card flex items-center justify-center hover:bg-cyan-500/20 transition-colors\" data-kid=\"260\"><i class=\"ti ti-brand-instagram\" data-kid=\"261\"></i></a>\n        <a href=\"#\" class=\"w-10 h-10 rounded-xl glass-card flex items-center justify-center hover:bg-cyan-500/20 transition-colors\" data-kid=\"262\"><i class=\"ti ti-brand-facebook\" data-kid=\"263\"></i></a>\n        <a href=\"#\" class=\"w-10 h-10 rounded-xl glass-card flex items-center justify-center hover:bg-cyan-500/20 transition-colors\" data-kid=\"264\"><i class=\"ti ti-brand-telegram\" data-kid=\"265\"></i></a>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script data-kid=\"266\">\n  window.addEventListener('load', () => {\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initial load animation for Hero\n    const heroTl = gsap.timeline();\n    heroTl.from('h1', { opacity: 0, y: 50, duration: 1, ease: 'power4.out' })\n          .from('p.text-xl', { opacity: 0, y: 30, duration: 1, ease: 'power4.out' }, '-=0.7')\n          .from('.flex.flex-wrap.items-center.gap-6', { opacity: 0, scale: 0.9, duration: 0.8, ease: 'back.out(1.7)' }, '-=0.6');\n\n    // Reveal animations on scroll\n    document.querySelectorAll('.reveal').forEach(el => {\n      gsap.to(el, {\n        opacity: 1,\n        y: 0,\n        duration: 1.2,\n        ease: 'power3.out',\n        scrollTrigger: {\n          trigger: el,\n          start: 'top 90%',\n          toggleActions: 'play none none none'\n        }\n      });\n    });\n\n    // Parallax effect for Map video\n    gsap.to('#map-video', {\n      yPercent: 20,\n      ease: 'none',\n      scrollTrigger: {\n        trigger: '#map-video',\n        start: 'top bottom',\n        end: 'bottom top',\n        scrub: true\n      }\n    });\n\n    // Hover tilt effect for cards\n    document.querySelectorAll('.glass-card').forEach(card => {\n      card.addEventListener('mousemove', (e) => {\n        const rect = card.getBoundingClientRect();\n        const x = e.clientX - rect.left;\n        const y = e.clientY - rect.top;\n        const centerX = rect.width / 2;\n        const centerY = rect.height / 2;\n        const rotateX = (y - centerY) / 20;\n        const rotateY = (centerX - x) / 20;\n        \n        gsap.to(card, {\n          rotateX: rotateX,\n          rotateY: rotateY,\n          duration: 0.3,\n          ease: 'power1.out',\n          transformPerspective: 1000\n        });\n      });\n      \n      card.addEventListener('mouseleave', () => {\n        gsap.to(card, {\n          rotateX: 0,\n          rotateY: 0,\n          duration: 0.5,\n          ease: 'power2.out'\n        });\n      });\n    });\n  });\n</script>",
