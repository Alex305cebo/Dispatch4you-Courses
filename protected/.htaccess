# Каталог с платным контентом. По HTTP отсюда нельзя забрать НИЧЕГО.
#
# Именно это делает починку настоящей: файлы модулей физически недостижимы
# запросом из браузера/curl. Отдаёт их только api/module.php через readfile(),
# то есть чтением с ДИСКА — файловый доступ не проходит через веб-сервер и под
# эти правила не попадает.
#
# Оба синтаксиса намеренно: Apache 2.4 понимает Require, 2.2 — Order/Deny.
# Версия на хостинге не проверена, поэтому перекрываем оба варианта; лишний
# блок безвреден, а пропущенный означал бы публичный платный контент.

<IfModule mod_authz_core.c>
  # Apache 2.4+
  Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
  # Apache 2.2
  Order allow,deny
  Deny from all
</IfModule>

# Подстраховка на случай, если оба модуля авторизации почему-то отключены:
# без mod_rewrite статику всё равно не отдать, а с ним — гасим запрос.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^ - [F,L]
</IfModule>

Options -Indexes
