---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    color: '#06b6d4',
    title: 'Реальная практика',
    desc: 'AI-симулятор переговоров с брокерами. 15+ сценариев от простых до сложных.',
    stat: '1,247',
    statLabel: 'диалогов отработано'
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    color: '#0ea5e9',
    title: 'Менторская поддержка',
    desc: 'Консультации с действующими диспетчерами. Ответы в течение часа, 24/7.',
    stat: '15+',
    statLabel: 'опытных менторов'
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>`,
    color: '#f97316',
    title: 'Карьерная подготовка',
    desc: 'Помощь с резюме, поиском работы и рекомендациями от партнёров.',
    stat: '92%',
    statLabel: 'трудоустроены'
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
    color: '#10b981',
    title: 'База знаний',
    desc: '15 страниц курса, 12 модулей тестов, документы и шаблоны.',
    stat: '15',
    statLabel: 'страниц курса'
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/><path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>`,
    color: '#a855f7',
    title: 'Аудио-уроки',
    desc: 'Учитесь в дороге. Все материалы доступны в аудиоформате.',
    stat: '40+',
    statLabel: 'аудио-уроков'
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>`,
    color: '#06b6d4',
    title: 'Постоянные обновления',
    desc: 'Актуальная информация о правилах, ставках и трендах рынка.',
    stat: '100%',
    statLabel: 'актуальный контент'
  },
];
---

<section id="features" class="relative py-32 px-6">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="reveal text-center mb-16">
      <span class="section-label mb-5 inline-flex">Возможности платформы</span>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mt-4 mb-4">
        Всё что нужно<br/>
        <span class="text-gradient">для старта карьеры</span>
      </h2>
      <p class="text-slate-500 text-lg max-w-xl mx-auto">
        Закрытая платформа с реальными инструментами диспетчера
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((f, i) => (
        <div
          class="reveal glass rounded-2xl p-6 group hover:glass-strong transition-all duration-300 hover:-translate-y-1 cursor-default"
          style={`transition-delay:${i * 0.07}s`}
        >
          <!-- Icon -->
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
            style={`background:${f.color}18; color:${f.color};`}
            set:html={f.icon}
          />

          <!-- Content -->
          <h3 class="font-semibold text-base text-slate-100 mb-2">{f.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed mb-4">{f.desc}</p>

          <!-- Stat -->
          <div class="pt-4 border-t border-white/5 flex items-baseline gap-2">
            <span class="text-2xl font-bold" style={`color:${f.color}`}>{f.stat}</span>
            <span class="text-xs text-slate-600">{f.statLabel}</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
