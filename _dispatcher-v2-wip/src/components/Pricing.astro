---
const plans = [
  {
    name: 'Базовый',
    price: '$297',
    period: 'единоразово',
    color: '#64748b',
    features: [
      '15 страниц курса',
      '12 модулей тестов',
      'База знаний',
      'Доступ 6 месяцев',
    ],
    cta: 'Начать',
    popular: false,
  },
  {
    name: 'Профи',
    price: '$497',
    period: 'единоразово',
    color: '#06b6d4',
    features: [
      'Всё из Базового',
      'AI-симулятор переговоров',
      'Аудио-уроки',
      'Менторская поддержка',
      'Помощь в трудоустройстве',
      'Доступ 12 месяцев',
    ],
    cta: 'Выбрать Профи',
    popular: true,
  },
  {
    name: 'VIP',
    price: '$797',
    period: 'единоразово',
    color: '#f97316',
    features: [
      'Всё из Профи',
      'Персональный ментор',
      'Разбор ваших кейсов',
      'Гарантия трудоустройства',
      'Пожизненный доступ',
    ],
    cta: 'Выбрать VIP',
    popular: false,
  },
];
---

<section id="pricing" class="relative py-32 px-6">
  <div class="divider mb-0"></div>

  <div class="max-w-5xl mx-auto pt-16">

    <!-- Header -->
    <div class="reveal text-center mb-16">
      <span class="section-label mb-5 inline-flex">Тарифы</span>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mt-4 mb-4">
        Выберите свой<br/>
        <span class="text-gradient">путь к карьере</span>
      </h2>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {plans.map((p, i) => (
        <div
          class={`reveal relative rounded-3xl p-7 flex flex-col transition-all duration-300 hover:-translate-y-1 ${p.popular ? 'ring-1 ring-cyan-500/40' : 'glass'}`}
          style={`transition-delay:${i * 0.1}s; ${p.popular ? `background:rgba(6,182,212,0.06); backdrop-filter:blur(40px) saturate(200%); -webkit-backdrop-filter:blur(40px) saturate(200%);` : ''}`}
        >
          {p.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="text-xs font-bold px-4 py-1.5 rounded-full bg-gradient-to-r from-cyan-500 to-blue-500 text-white">
                Популярный
              </span>
            </div>
          )}

          <div class="mb-6">
            <div class="text-sm font-semibold mb-3" style={`color:${p.color}`}>{p.name}</div>
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-black text-slate-100">{p.price}</span>
              <span class="text-sm text-slate-600">{p.period}</span>
            </div>
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            {p.features.map(f => (
              <li class="flex items-center gap-3 text-sm text-slate-400">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={p.color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href="#"
            class={`btn-apple text-center justify-center text-sm py-3 ${p.popular ? 'btn-primary' : ''}`}
            style={!p.popular ? `border-color:${p.color}30;` : ''}
          >
            {p.cta}
          </a>
        </div>
      ))}
    </div>

  </div>
</section>
