---
const steps = [
  {
    num: '01',
    title: 'Основы индустрии',
    time: '1–2 недели',
    color: '#06b6d4',
    items: ['Рынок грузоперевозок США', 'Роль диспетчера', 'Терминология и документы']
  },
  {
    num: '02',
    title: 'Работа с грузами',
    time: '2–3 недели',
    color: '#0ea5e9',
    items: ['Load Boards: DAT, Truckstop', 'Типы оборудования', 'Маршруты и ставки']
  },
  {
    num: '03',
    title: 'Переговоры',
    time: '2–3 недели',
    color: '#a855f7',
    items: ['Работа с брокерами', 'AI-симулятор диалогов', 'Реальные кейсы']
  },
  {
    num: '04',
    title: 'Документация',
    time: '1 неделя',
    color: '#10b981',
    items: ['Rate Con, BOL, POD', 'Invoice и Carrier Packet', 'Проверка документов']
  },
  {
    num: '05',
    title: 'Старт карьеры',
    time: '1–2 недели',
    color: '#f97316',
    items: ['Резюме и портфолио', 'Поиск первого клиента', 'Поддержка до трудоустройства']
  },
];
---

<section id="program" class="relative py-32 px-6">
  <div class="divider mb-0"></div>

  <div class="max-w-5xl mx-auto pt-16">

    <!-- Header -->
    <div class="reveal text-center mb-16">
      <span class="section-label mb-5 inline-flex">Программа обучения</span>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mt-4 mb-4">
        От нуля до<br/>
        <span class="text-gradient-cyan">первой работы</span>
      </h2>
      <p class="text-slate-500 text-lg">8–10 недель интенсивного обучения</p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-cyan-500/30 via-blue-500/20 to-transparent hidden md:block"></div>

      <div class="space-y-4">
        {steps.map((s, i) => (
          <div class="reveal flex gap-6 group" style={`transition-delay:${i * 0.1}s`}>

            <!-- Number circle -->
            <div
              class="relative z-10 flex-shrink-0 w-16 h-16 rounded-2xl flex items-center justify-center font-black text-lg hidden md:flex"
              style={`background:${s.color}15; border:1px solid ${s.color}30; color:${s.color};`}
            >
              {s.num}
            </div>

            <!-- Card -->
            <div class="flex-1 glass rounded-2xl p-6 group-hover:glass-strong transition-all duration-300 hover:-translate-y-0.5">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                <div>
                  <span class="text-xs font-semibold uppercase tracking-widest mb-1 block" style={`color:${s.color}`}>
                    Этап {s.num}
                  </span>
                  <h3 class="text-lg font-bold text-slate-100">{s.title}</h3>
                </div>
                <span class="text-xs text-slate-600 bg-white/5 px-3 py-1.5 rounded-full border border-white/8">
                  {s.time}
                </span>
              </div>
              <div class="flex flex-wrap gap-2">
                {s.items.map(item => (
                  <span class="text-xs text-slate-400 bg-white/4 px-3 py-1.5 rounded-lg border border-white/6">
                    {item}
                  </span>
                ))}
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>

  </div>
</section>
