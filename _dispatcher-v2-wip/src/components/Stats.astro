---
const stats = [
  { value: '500+', label: 'Студентов обучено', color: '#06b6d4' },
  { value: '92%', label: 'Трудоустроены', color: '#10b981' },
  { value: '$3,500', label: 'Средний старт', color: '#f97316' },
  { value: '24/7', label: 'Поддержка', color: '#a855f7' },
];
---

<section class="relative py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="glass rounded-3xl p-10 md:p-14 grid grid-cols-2 md:grid-cols-4 gap-8 reveal">
      {stats.map(s => (
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-black mb-2" style={`color:${s.color}`}>{s.value}</div>
          <div class="text-sm text-slate-500">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
