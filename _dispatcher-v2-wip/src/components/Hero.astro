---
---

<section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">

  <!-- Ambient orbs — inline styles, position:absolute внутри секции -->
  <div data-orb style="position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(6,182,212,0.18) 0%,transparent 70%);filter:blur(80px);top:-200px;left:-200px;pointer-events:none;z-index:0;"></div>
  <div data-orb style="position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(14,165,233,0.14) 0%,transparent 70%);filter:blur(80px);top:30%;right:-200px;pointer-events:none;z-index:0;"></div>
  <div data-orb style="position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(99,102,241,0.10) 0%,transparent 70%);filter:blur(80px);bottom:-100px;left:30%;pointer-events:none;z-index:0;"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">

    <!-- Label -->
    <div class="reveal" style="display:flex;justify-content:center;margin-bottom:2rem;">
      <span class="section-label">
        <span style="width:6px;height:6px;border-radius:50%;background:#06b6d4;display:inline-block;animation:pulse 2s infinite;"></span>
        Профессия будущего · Удалённая работа
      </span>
    </div>

    <!-- Headline -->
    <h1 class="reveal" style="font-size:clamp(40px,7vw,72px);font-weight:900;letter-spacing:-0.03em;line-height:1.05;margin-bottom:1.5rem;transition-delay:0.1s;">
      Станьте<br/>
      <span class="text-gradient-cyan">Диспетчером</span><br/>
      <span style="color:#64748b;font-weight:300;font-size:0.72em;letter-spacing:-0.01em;">Грузоперевозок США</span>
    </h1>

    <!-- Subtitle -->
    <p class="reveal" style="font-size:clamp(16px,2vw,20px);color:#64748b;max-width:560px;margin:0 auto 2.5rem;line-height:1.7;transition-delay:0.2s;">
      Удалённая профессия с доходом от $3,500 в месяц.<br/>
      Обучение с нуля — опыт и английский не нужны.
    </p>

    <!-- CTA row -->
    <div class="reveal" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:12px;margin-bottom:3.5rem;transition-delay:0.3s;">
      <a href="#program" class="btn-apple btn-primary" style="font-size:15px;padding:14px 32px;gap:10px;">
        Смотреть программу
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="#features" class="btn-apple" style="font-size:15px;padding:14px 32px;">
        Узнать подробнее
      </a>
    </div>

    <!-- Social proof -->
    <div class="reveal" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:20px;font-size:13px;color:#475569;transition-delay:0.4s;">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="display:flex;margin-right:4px;">
          {[0,1,2,3].map(() => (
            <div style="width:28px;height:28px;border-radius:50%;border:2px solid #0f172a;background:linear-gradient(135deg,#334155,#1e293b);margin-left:-6px;"></div>
          ))}
        </div>
        <span>500+ студентов</span>
      </div>
      <span style="width:1px;height:16px;background:#1e293b;display:inline-block;"></span>
      <div style="display:flex;align-items:center;gap:6px;">
        <span style="color:#fbbf24;">★★★★★</span>
        <span>4.8 рейтинг</span>
      </div>
      <span style="width:1px;height:16px;background:#1e293b;display:inline-block;"></span>
      <span>92% трудоустроены</span>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:#1e293b;">
    <span style="font-size:10px;letter-spacing:0.15em;text-transform:uppercase;">Scroll</span>
    <div style="width:1px;height:40px;background:linear-gradient(to bottom,#334155,transparent);"></div>
  </div>

</section>

<style>
  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50% { opacity:0.5; transform:scale(1.3); }
  }
</style>
