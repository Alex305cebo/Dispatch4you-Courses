# Apache конфигурация для dispatch4you.com

# Включение mod_rewrite
RewriteEngine On

# favicon.ico -> favicon.svg
RewriteRule ^favicon\.ico$ favicon.svg [L,T=image/svg+xml]

# Редирект с www на без www
RewriteCond %{HTTP_HOST} ^www\.dispatch4you\.com [NC]
RewriteRule ^(.*)$ https://dispatch4you.com/$1 [L,R=301]

# Редирект HTTP на HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ========================================
# Firebase Auth files — serve without extension as HTML
# ========================================
<FilesMatch "^(handler|iframe|links)$">
  ForceType text/html
</FilesMatch>

# ========================================
# Стандартные пути с /pages/
# ========================================

# Кэширование статических файлов
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType audio/mpeg "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  # HTML не кешируем
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Добавляем Cache-Control заголовки для лучшего кэширования
<IfModule mod_headers.c>
  # Статические ресурсы - агрессивное кэширование
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|css|js|woff|woff2|mp3)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # HTML - не кешируем
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Разрешаем запросы к Groq API и Firebase (для симулятора и авторизации)
<IfModule mod_headers.c>
  # Разрешаем popup окна для Firebase Authentication
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  Header always set Cross-Origin-Embedder-Policy "unsafe-none"
  
  # CSP управляется на уровне Hostinger — не переопределяем здесь
  # Header always set Content-Security-Policy "..."
</IfModule>

# Отключаем кеш для файлов симулятора
<FilesMatch "(simulator\.html|scenarios-inline\.js|scenarios-data.*\.js)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </IfModule>
</FilesMatch>

# Сжатие файлов (Gzip)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/xhtml+xml application/rss+xml application/atom+xml image/svg+xml
  
  # Не сжимаем уже сжатые файлы
  SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|woff2?)$ no-gzip
  
  # Убираем баги старых браузеров
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  
  # Добавляем заголовок Vary для прокси
  Header append Vary User-Agent env=!dont-vary
</IfModule>

# Защита файлов конфигурации
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

# Защита от просмотра директорий
Options -Indexes

# Кастомные страницы ошибок
ErrorDocument 404 /404.html
ErrorDocument 500 /404.html
