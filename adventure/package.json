{
  "name": "office4dispatch",
  "version": "2.2.0-beta.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "postbuild:web": "node scripts/fix-paths.js && node scripts/copy-truck-images.js",
    "build:local": "expo export --platform web && node scripts/fix-paths-local.js && node scripts/copy-truck-images.js"
  },
  "dependencies": {
    "@amcharts/amcharts5": "^5.17.1",
    "@amcharts/amcharts5-geodata": "^5.1.5",
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-haptics": "~14.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "lottie-react": "^2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "sharp": "^0.34.5",
    "typescript": "~5.3.0"
  },
