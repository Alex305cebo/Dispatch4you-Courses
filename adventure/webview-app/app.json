{
  "expo": {
    "name": "Office 4 Dispatch",
    "slug": "office4dispatch",
    "scheme": "office4dispatch",
    "version": "3.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dispatch4you.adventure",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.dispatch4you.adventure",
      "versionCode": 1
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "501ba716-ec91-47e6-94d8-47d693aa0fb3"
      }
    },
    "owner": "office4dispatch"
  }
}
